module () where

const test = (const target) => if import.meta.mode == #test {
  `Export ()
} else {
  `Drop ()
}

const derive = (const ...generators) => (const target) => `Replace (comptime {
  let derived = target

  for generator in generators {
    derived = @type.extend(derived, generator(derived))
  }

  derived
})

return { test, derive }
