module () where

const { .parse_delete_options } = import "./cli_sessions.duck" ();
const {} = import "./cli_types.duck" ();

type FixtureArgs = CodexCliArgs
type FixtureResult = CodexDeleteOptionsResult
type FixtureNode = ListNode Text

const prepend_arg = (value: Text, values: FixtureArgs) => {
  let node: FixtureNode = [value, values];
  let result: FixtureArgs = `Cons node;
  result
};
const singleton_arg = (value: Text) => {
  let empty: FixtureArgs = `Nil ();
  prepend_arg(value, empty)
};
let uuid_input: FixtureArgs = prepend_arg(
  "--force",
  singleton_arg "123e4567-e89b-12d3-a456-426614174000",
);
let uuid_result: FixtureResult = parse_delete_options uuid_input;
let name_input: FixtureArgs = prepend_arg("--force", singleton_arg "my-thread");
let name_result: FixtureResult = parse_delete_options name_input;
let score = 0;

if let `Ok options = uuid_result {
  if options.force && options.target == "123e4567-e89b-12d3-a456-426614174000" { score = score + 1 }
}

if let `Err message = name_result {
  if message == "--force requires a session UUID; names must be confirmed interactively" { score = score + 10 }
}

return { .score = score };
