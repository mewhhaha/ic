module () where

const {} = import "./request_user_input_types.duck" ();
const { .encode_request_user_input_response } = import "./request_user_input_output.duck" ();

type FixtureAnswer = RequestUserInputAnswer
type FixtureAnswerNode = RequestUserInputAnswerNode
type FixtureAnswers = RequestUserInputAnswers
type FixtureResponse = RequestUserInputResponse
type FixtureTextNode = RequestUserInputAnswerTextNode
type FixtureTexts = RequestUserInputAnswerTexts

let answers: FixtureAnswers = `Cons (
  [
    [
      .question_id = "pick_one",
      .answers = `Cons (
        ["A", `Cons (["custom \"answer\"", `Nil ()] as FixtureTextNode)] as FixtureTextNode
      ),
    ] as FixtureAnswer,
    `Cons (
      [[.question_id = "confirm", .answers = `Nil ()] as FixtureAnswer, `Nil ()] as FixtureAnswerNode
    ) ] as FixtureAnswerNode
);
let response: FixtureResponse = [.answers = answers];
let score =
  if encode_request_user_input_response response == "{\"answers\":{\"pick_one\":{\"answers\":[\"A\",\"custom \\\"answer\\\"\"]},\"confirm\":{\"answers\":[]}}}" { 1 } else { 0 };

return { .score = score };
