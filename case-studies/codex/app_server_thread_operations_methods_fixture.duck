module () where

const { .json_object, .json_object_empty, .json_object_prepend, .json_string } =
  import "duck:prelude/json" ();
const {
  .decode_thread_archive,
  .decode_thread_compact_start,
  .decode_thread_unarchive,
  .decode_thread_unsubscribe,
} = import "./app_server_thread_methods.duck" ();
const {} = import "./app_server_types.duck" ();

const params = () => json_object(
  json_object_prepend("threadId", json_string "thread-1", json_object_empty())
);

let archive = decode_thread_archive(params());
let unarchive = decode_thread_unarchive(params());
let unsubscribe = decode_thread_unsubscribe(params());
let compact = decode_thread_compact_start(params());
let score = 0;

if let `MethodOk method = archive { if let `ThreadArchive id = method { if id == "thread-1" { score = score + 1 } } }
if let `MethodOk method = unarchive { if let `ThreadUnarchive id = method { if id == "thread-1" {
  score = score + 10 } } }
if let `MethodOk method = unsubscribe { if let `ThreadUnsubscribe id = method { if id == "thread-1" { score = score + 100 } } }
if let `MethodOk method = compact { if let `ThreadCompactStart id = method { if id == "thread-1" {
  score = score + 1000 } } }

return { .score = score };
