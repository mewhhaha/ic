module () where

const {
  .encode_json,
  .json_object,
  .json_object_empty,
  .json_object_get,
  .json_object_prepend,
  .json_string,
  .parse_json_document,
} = import "duck:prelude/json" ();
const { .list } = import "duck:prelude/functional" ();
const { .text_append, .text_get, .text_length } = import "duck:prelude/runtime" ();
const {} = import "./app_server_types.duck" ();

type ServerJson = AppServerJson
type ServerJsonObject = JsonObject
type ServerJsonArray = JsonArray
type ServerJsonLookup = JsonLookupResult
type ServerTextOption = AppServerTextOption
type ServerTexts = AppServerTexts
type ServerRequestId = AppServerRequestId
type ServerClientInfo = AppServerClientInfo
type ServerCapabilities = AppServerCapabilities
type ServerTextArrayResult = AppServerTextArrayResult
type ServerCapabilitiesResult = AppServerCapabilitiesResult
type ServerInitializedSession = AppServerInitializedSession
type ServerSession = AppServerSession
type ServerRequest = AppServerRequest
type ServerNotification = AppServerNotification
type ServerResponse = AppServerResponse
type ServerPeerError = AppServerPeerError
type ServerMessage = AppServerMessage
type ServerDecodeResult = AppServerDecodeResult
type ServerIdentity = AppServerIdentity
type ServerSend = AppServerSend
type ServerRoute = AppServerRoute
type ServerObserve = AppServerObserve
type ServerDrop = AppServerDrop
type ServerPlan = AppServerPlan
type ServerInitializeResult = AppServerInitializeResult

const texts = comptime list Text;

const uninitialized_app_server_session: () -> ServerSession = () => `Uninitialized ();

const json_null_value: () -> ServerJson = () => `Null ();

const request_id_number_valid: Text -> Bool = (number: Text) => {
  let length = text_length number;
  let index = 0;
  let valid = length > 0;
  let done = false;

  if valid {
    if text_get [number, 0] == 45 {
      index = 1
      if index == length { valid = false }
    }
  }

  loop {
    if index >= length {
      done = true
    } else {
      let byte = text_get [number, index];

      if byte < 48 || byte > 57 {
        valid = false
        done = true
      } else {
        index = index + 1
      }
    }

    if done {
      break;
    }
  }

  valid
};

const request_id_valid: ServerJson -> Bool = (value: ServerJson) => {
  if let `String _ = value {
    true
  } else if let `Number number = value {
    request_id_number_valid number
  } else {
    false
  }
};

const lookup_or_null: [ServerJsonObject, Text] -> ServerJson = (object: ServerJsonObject, key: Text) => {
    let lookup: ServerJsonLookup = json_object_get(key, object);

    if let `Found value = lookup {
      value
    } else {
      json_null_value()
    }
  };

const required_text: [ServerJsonObject, Text] -> ServerTextOption = (
  object: ServerJsonObject,
  key: Text,
) => {
  let lookup: ServerJsonLookup = json_object_get(key, object);

  if let `Found value = lookup {
    if let `String text = value { `Some text } else { `None () }
  } else {
    `None ()
  }
};

const optional_text: [ServerJsonObject, Text] -> ServerTextOption = (
  object: ServerJsonObject,
  key: Text,
) => {
  let lookup: ServerJsonLookup = json_object_get(key, object);

  if let `Found value = lookup {
    if let `String text = value { `Some text } else { `None () }
  } else {
    `None ()
  }
};

const optional_text_valid: [ServerJsonObject, Text] -> Bool = (object: ServerJsonObject, key: Text) => {
    let lookup: ServerJsonLookup = json_object_get(key, object);

    if let `Found value = lookup {
      if let `Null () = value {
        true
      } else if let `String _ = value {
        true
      } else {
        false
      }
    } else {
      true
    }
  };

const optional_bool: [ServerJsonObject, Text] -> Bool = (object: ServerJsonObject, key: Text) => {
  let lookup: ServerJsonLookup = json_object_get(key, object);

  if let `Found value = lookup {
    if let `Bool boolean = value { boolean } else { false }
  } else {
    false
  }
};

const optional_bool_valid: [ServerJsonObject, Text] -> Bool = (object: ServerJsonObject, key: Text) => {
    let lookup: ServerJsonLookup = json_object_get(key, object);

    if let `Found value = lookup {
      if let `Null () = value {
        true
      } else if let `Bool _ = value {
        true
      } else {
        false
      }
    } else {
      true
    }
  };

const decode_text_array: ServerJson -> ServerTextArrayResult = (value: ServerJson) => {
  if let `Array values = value {
    let current = values;
    let reversed = texts.empty();
    let valid = true;
    let done = false;

    loop {
      if let `Cons node = current {
        let [entry, tail] = node;

        if let `String text = entry {
          reversed = texts.prepend(text, reversed)
          current = tail
        } else {
          valid = false
          done = true
        }
      } else {
        done = true
      }

      if done { break; }
    }

    if valid {
      `TextArrayOk (texts.reverse(reversed))
    } else {
      `TextArrayError "optOutNotificationMethods must contain only strings"
    }
  } else {
    `TextArrayError "optOutNotificationMethods must be an array"
  }
};

const client_name_valid: Text -> Bool = (name: Text) => {
  let valid = true;
  let index = 0;
  let length = text_length name;
  let done = false;

  loop {
    if index >= length {
      done = true
    } else {
      let byte = text_get [name, index];

      if byte < 32 {
        if byte != 9 { valid = false }
      } else if byte == 127 {
        valid = false
      }

      index = index + 1
    }

    if done {
      break;
    }
  }

  valid
};

const decode_capabilities: ServerJsonObject -> ServerCapabilitiesResult = (params: ServerJsonObject) => {
    let experimental_api = false;
    let request_attestation = false;
    let openai_form = false;
    let opt_out = texts.empty();
    let error: Text = "";
    let lookup: ServerJsonLookup = json_object_get("capabilities", params);

    if let `Found value = lookup {
      if let `Null () = value {
        ()
      } else if let `Object object = value {
        if optional_bool_valid(object, "experimentalApi") {
          experimental_api = optional_bool(object, "experimentalApi")
        } else {
          error = "initialize.params.capabilities.experimentalApi must be a boolean or null"
        }

        if text_length error == 0 {
          if optional_bool_valid(object, "requestAttestation") {
            request_attestation = optional_bool(object, "requestAttestation")
          } else {
            error = "initialize.params.capabilities.requestAttestation must be a boolean or null"
          }
        }

        if text_length error == 0 {
          if optional_bool_valid(object, "mcpServerOpenaiFormElicitation") {
            openai_form = optional_bool(object, "mcpServerOpenaiFormElicitation")
          } else {
            error = "initialize.params.capabilities.mcpServerOpenaiFormElicitation must be a boolean or null"
          }
        }

        if text_length error == 0 {
          let methods: ServerJsonLookup = json_object_get("optOutNotificationMethods", object);

          if let `Found method_values = methods {
            if let `Null () = method_values {
              ()
            } else {
              let decoded = decode_text_array method_values;

              if let `TextArrayOk values = decoded {
                opt_out = values
              } else if let `TextArrayError reason = decoded {
                error = text_append ["initialize.params.capabilities.", reason]
              }
            }
          }
        }
      } else {
        error = "initialize.params.capabilities must be an object or null"
      }
    }

    let capabilities: ServerCapabilities = [
      experimental_api,
      request_attestation,
      openai_form,
      opt_out,
    ];
    if text_length error == 0 {
      `CapabilitiesOk capabilities
    } else {
      `CapabilitiesError error
    }
  };

const decode_initialize: ServerJson -> ServerInitializeResult = (params: ServerJson) => {
  let result: ServerInitializeResult = `InitializeError "initialize.params must be an object";

  if let `Object object = params {
    let client_lookup: ServerJsonLookup = json_object_get("clientInfo", object);

    if let `Found client_value = client_lookup {
      if let `Object client = client_value {
        let name = required_text(client, "name");
        let version = required_text(client, "version");

        if let `Some client_name = name {
          if let `Some client_version = version {
            if optional_text_valid(client, "title") {
              if client_name_valid client_name {
                let capabilities_result = decode_capabilities object;

                if let `CapabilitiesOk capabilities = capabilities_result {
                  let info: ServerClientInfo = [
                    client_name,
                    optional_text(client, "title"),
                    client_version,
                  ];
                  let initialized: ServerInitializedSession = [info, capabilities];
                  result = `InitializeOk initialized
                } else if let `CapabilitiesError error = capabilities_result {
                  result = `InitializeError error
                }
              } else {
                let prefix = text_append ["Invalid clientInfo.name: '", client_name];
                result = `InitializeError (
                  text_append [prefix, "'. Must be a valid HTTP header value."]
                )
              }
            } else {
              result = `InitializeError "initialize.params.clientInfo.title must be a string or null"
            }
          } else {
            result = `InitializeError "initialize.params.clientInfo.version must be a string"
          }
        } else {
          result = `InitializeError "initialize.params.clientInfo.name must be a string"
        }
      } else {
        result = `InitializeError "initialize.params.clientInfo must be an object"
      }
    } else {
      result = `InitializeError "initialize.params.clientInfo is required"
    }
  }

  result
};

const decode_peer_error: [ServerRequestId, ServerJson] -> ServerDecodeResult = (
  id: ServerRequestId,
  value: ServerJson,
) => {
  if let `Object object = value {
    let code_lookup: ServerJsonLookup = json_object_get("code", object);
    let message = required_text(object, "message");

    if let `Found code_value = code_lookup {
      if let `Number code = code_value {
        if request_id_number_valid code {
          if let `Some error_message = message {
            let peer_error: ServerPeerError = [
              id,
              code,
              error_message,
              lookup_or_null(object, "data"),
            ];
            `Decoded (`PeerError peer_error);
          } else {
            `DecodeError "error response message must be a string"
          }
        } else {
          `DecodeError "error response code must be an integer"
        }
      } else {
        `DecodeError "error response code must be an integer"
      }
    } else {
      `DecodeError "error response code is required"
    }
  } else {
    `DecodeError "error response must contain an error object"
  }
};

const decode_app_server_message: Text -> ServerDecodeResult = (document: Text) => {
  let parsed = parse_json_document document;

  if let `Err error = parsed {
    let [_, message] = error;
    `DecodeError message;
  } else if let `Ok value_and_index = parsed {
    let [value, _] = value_and_index;

    if let `Object object = value {
      let method_lookup: ServerJsonLookup = json_object_get("method", object);
      let id_lookup: ServerJsonLookup = json_object_get("id", object);

      if let `Found method_value = method_lookup {
        if let `String method = method_value {
          let params = lookup_or_null(object, "params");

          if let `Found id = id_lookup {
            if request_id_valid id {
              let request: ServerRequest = [id, method, params];
              `Decoded (`Request request);
            } else {
              `DecodeError "request id must be a string or integer"
            }
          } else {
            let notification: ServerNotification = [method, params];
            `Decoded (`Notification notification);
          }
        } else {
          `DecodeError "message method must be a string"
        }
      } else if let `Found id = id_lookup {
        if request_id_valid id {
          let response_lookup: ServerJsonLookup = json_object_get("result", object);
          let error_lookup: ServerJsonLookup = json_object_get("error", object);

          if let `Found response_value = response_lookup {
            let response: ServerResponse = [id, response_value];
            `Decoded (`Response response);
          } else if let `Found error_value = error_lookup {
            decode_peer_error(id, error_value)
          } else {
            `DecodeError "response must contain result or error"
          }
        } else {
          `DecodeError "response id must be a string or integer"
        }
      } else {
        `DecodeError "message must contain method or id"
      }
    } else {
      `DecodeError "message must be a JSON object"
    }
  } else {
    `DecodeError "invalid JSON parse result"
  }
};

const encode_response: [ServerRequestId, ServerJson] -> Text = (
  id: ServerRequestId,
  result: ServerJson,
) => {
  let fields = json_object_empty();
  fields = json_object_prepend("result", result, fields)
  fields = json_object_prepend("id", id, fields)
  encode_json(json_object fields)
};

const encode_error: [ServerRequestId, Text, Text] -> Text = (
  id: ServerRequestId,
  code: Text,
  message: Text,
) => {
  let error_fields = json_object_empty();
  error_fields = json_object_prepend("message", json_string message, error_fields)
  error_fields = json_object_prepend("code", `Number code, error_fields)
  let fields = json_object_empty();
  fields = json_object_prepend("error", json_object error_fields, fields)
  fields = json_object_prepend("id", id, fields)
  encode_json(json_object fields)
};

const initialize_response: ServerIdentity -> ServerJson = (identity: ServerIdentity) => {
  let [user_agent, codex_home, platform_family, platform_os] = identity;
  let fields = json_object_empty();
  fields = json_object_prepend("platformOs", json_string platform_os, fields)
  fields = json_object_prepend("platformFamily", json_string platform_family, fields)
  fields = json_object_prepend("codexHome", json_string codex_home, fields)
  fields = json_object_prepend("userAgent", json_string user_agent, fields)
  json_object fields
};

const handle_request: [ServerSession, ServerIdentity, ServerRequest] -> ServerPlan = (
  session: ServerSession,
  identity: ServerIdentity,
  request: ServerRequest,
) => {
  let [id, method, params] = request;
  let plan: ServerPlan = `Drop ([session, "request method could not be decoded"]);

  if method == "initialize" {
    if let `Initialized _ = session {
      let send: ServerSend = [session, encode_error(id, "-32600", "Already initialized")];
      plan = `Send send
    } else {
      let initialized = decode_initialize params;

      if let `InitializeOk initialized_session = initialized {
        let next: ServerSession = `Initialized initialized_session;
        let send: ServerSend = [next, encode_response(id, initialize_response identity)];
        plan = `Send send
      } else if let `InitializeError message = initialized {
        let send: ServerSend = [session, encode_error(id, "-32600", message)];
        plan = `Send send
      }
    }
  } else if let `Uninitialized () = session {
    let send: ServerSend = [session, encode_error(id, "-32600", "Not initialized")];
    plan = `Send send
  } else {
    let route: ServerRoute = [session, id, method, params];
    plan = `Route route
  }

  plan
};

const handle_app_server_line: [ServerSession, ServerIdentity, Text] -> ServerPlan = (
  session: ServerSession,
  identity: ServerIdentity,
  document: Text,
) => {
  let decoded = decode_app_server_message document;

  if let `Decoded message = decoded {
    if let `Request request = message {
      handle_request(session, identity, request)
    } else {
      let observed: ServerObserve = [session, message];
      `Observe observed;
    }
  } else if let `DecodeError message = decoded {
    let dropped: ServerDrop = [session, message];
    `Drop dropped;
  } else {
    let dropped: ServerDrop = [session, "could not classify app-server message"];
    `Drop dropped;
  }
};

const notification_opted_out: [ServerTexts, Text] -> Bool = (values: ServerTexts, method: Text) => {
  let current = values;
  let opted_out = false;
  let done = false;

  loop {
    if let `Cons node = current {
      let [candidate, tail] = node;

      if candidate == method {
        opted_out = true
        done = true
      } else {
        current = tail
      }
    } else {
      done = true
    }

    if done {
      break;
    }
  }

  opted_out
};

const should_emit_notification: [ServerSession, Text] -> Bool = (
  session: ServerSession,
  method: Text,
) => {
  if let `Initialized initialized = session {
    let [_, capabilities] = initialized;
    let [_, _, _, opt_out] = capabilities;
    if notification_opted_out(opt_out, method) { false } else { true }
  } else {
    false
  }
};

const experimental_api_enabled: ServerSession -> Bool = (session: ServerSession) => {
  if let `Initialized initialized = session {
    let [_, capabilities] = initialized;
    let [enabled, _, _, _] = capabilities;
    enabled
  } else {
    false
  }
};

return {
  .uninitialized_app_server_session,
  .decode_app_server_message,
  .encode_response,
  .encode_error,
  .handle_app_server_line,
  .should_emit_notification,
  .experimental_api_enabled,
};
