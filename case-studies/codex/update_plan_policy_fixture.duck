module () where

const {} = import "./update_plan_types.duck" ();
const { .plan_parsed_update_plan, .plan_update_plan_payload, .update_plan_completion } =
  import "./update_plan_policy.duck" ();

type FixtureArgs = UpdatePlanArgs
type FixtureStep = UpdatePlanStep
type FixtureStepNode = UpdatePlanStepNode
type FixtureSteps = UpdatePlanSteps

let score = 0;

if let `RejectPayload message = plan_update_plan_payload(`Unsupported (), `Plan ()) {
  if message == "update_plan handler received unsupported payload" { score = score + 1 }
}

if let `RejectPayload message = plan_update_plan_payload(`Function "not json", `Plan ()) {
  if message == "update_plan is a TODO/checklist tool and is not allowed in Plan mode" { score = score + 10 }
}

if let `ParseArguments arguments = plan_update_plan_payload(`Function "{}", `Default ()) {
  if arguments == "{}" { score = score + 100 }
}

let steps: FixtureSteps = `Cons (
  [
    [.step = "compile", .status = `InProgress ()] as FixtureStep,
    `Cons ([[.step = "test", .status = `InProgress ()] as FixtureStep, `Nil ()] as FixtureStepNode),
  ] as FixtureStepNode
);
let args: FixtureArgs = [.explanation = `Some "Keep both active", .plan = steps];
if let `Publish published = plan_parsed_update_plan args {
  if let `Some explanation = published.explanation {
    if explanation == "Keep both active" {
      if let `Cons first_node = published.plan {
        let [first, tail] = first_node;
        if first.step == "compile" {
          if let `InProgress () = first.status {
            if let `Cons second_node = tail {
              let [second, end] = second_node;
              if second.step == "test" {
                if let `InProgress () = second.status {
                  if let `Nil () = end { score = score + 1000 }
                }
              }
            }
          }
        }
      }
    }
  }
}

let completion = update_plan_completion();
if completion.text == "Plan updated" && completion.success && completion.code_mode == "{}" {
  score = score + 10000
}

return { .score = score };
