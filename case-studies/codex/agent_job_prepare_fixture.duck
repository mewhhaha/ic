module () where

const { .text_contains } = import "duck:prelude/runtime" ();
const {} = import "./agent_job_prepare_types.duck" ();
const { .parse_agent_job_csv } = import "./agent_job_csv.duck" ();
const { .prepare_agent_job } = import "./agent_job_prepare.duck" ();

type FixtureArgs = AgentJobSpawnArgs

let score = 0;
let parsed =
  parse_agent_job_csv "id,path,area\nx,src/lib.rs,test\nx,docs/readme.md,docs\n,README.md,root\n";
if let `CsvParsed document = parsed {
  let args: FixtureArgs = [
    .input_path = "/workspace/input.csv",
    .instruction = "Review {path} in {area}. Keep {{literal}}.",
    .id_column = `Some "id",
    .output_path = `None (),
    .output_schema_json = `Some "{\"type\":\"object\",\"properties\":{\"ok\":{\"type\":\"boolean\"}}}",
    .max_concurrency = 8,
    .max_runtime_seconds = `Some "1800",
  ];
  let prepared = prepare_agent_job("12345678-abcd", args, document);
  if let `JobPrepared job = prepared {
    if job.name == "agent-job-12345678" && job.output_path == "/workspace/input.agent-job-12345678.csv" {
      score = score + 1
    }
    if let `Cons first_node = job.items {
      let [first, tail] = first_node;
      if first.item_id == "x" && first.row_index == 0 && first.row_json == "{\"area\":\"test\",\"id\":\"x\",\"path\":\"src/lib.rs\"}" && text_contains [
        first.prompt,
        "Task instruction:\nReview src/lib.rs in test. Keep {literal}.",
      ] && text_contains [
        first.prompt,
        "Expected result schema (JSON Schema or {}):\n{\n  \"type\": \"object\",",
      ] {
        score = score + 10
      }
      if let `Cons second_node = tail {
        let [second, tail] = second_node;
        if second.item_id == "x-2" { score = score + 100 }
        if let `Cons third_node = tail {
          let [third, end] = third_node;
          if third.item_id == "row-3" {
            if let `Nil () = end { score = score + 1000 }
          }
        }
      }
    }
  }
}

let duplicate = parse_agent_job_csv "id,id\n1,2\n";
if let `CsvParsed document = duplicate {
  let args: FixtureArgs = [
    .input_path = "/workspace/input.csv",
    .instruction = "run",
    .id_column = `None (),
    .output_path = `None (),
    .output_schema_json = `None (),
    .max_concurrency = 1,
    .max_runtime_seconds = `None (),
  ];
  if let `JobPreparationFailed message = prepare_agent_job("job", args, document) {
    if message == "csv header id is duplicated" { score = score + 10000 }
  }
}

return { .score = score };
