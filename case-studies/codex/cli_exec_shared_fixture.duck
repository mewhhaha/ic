module () where

const { .parse_exec_options } = import "./cli_exec.duck" ();
const {} = import "./cli_types.duck" ();

type FixtureArgs = CodexCliArgs
type FixtureResult = CodexExecOptionsResult

const empty_args = () => {
  let values: FixtureArgs = `Nil ();
  values
};

const prepend_arg: [Text, FixtureArgs] -> FixtureArgs = (value: Text, tail: FixtureArgs) => {
  let node: ListNode Text = [value, tail];
  let values: FixtureArgs = `Cons node;
  values
};

let input: FixtureArgs = prepend_arg("summarize", empty_args());
input = prepend_arg("/tmp/extra", input)
input = prepend_arg("--add-dir", input)
input = prepend_arg("workspace-write", input)
input = prepend_arg("--sandbox", input)
input = prepend_arg("a.png,b.png", input)
input = prepend_arg("--image", input)
input = prepend_arg("gpt-test", input)
input = prepend_arg("--model", input)
let parsed: FixtureResult = parse_exec_options input;
let score = if let `Ok options = parsed {
  if let `Some model = options.shared.model {
    if let `Cons first_image_node = options.shared.images {
      let [first_image, remaining_images] = first_image_node;
      if let `Cons second_image_node = remaining_images {
        let [second_image, _] = second_image_node;
        if let `Cons writable_node = options.shared.additional_writable_roots {
          let [writable, _] = writable_node;
          let sandbox_ok = if let `Some mode = options.shared.sandbox { if let `SandboxWorkspaceWrite () = mode { true } else { false } } else { false };
          if model == "gpt-test" && first_image == "a.png" && second_image == "b.png" && writable == "/tmp/extra" && sandbox_ok { 1 } else { 0 }
        } else { 0 }
      } else { 0 }
    } else { 0 }
  } else { 0 }
} else { 0 };

return { .score = score };
