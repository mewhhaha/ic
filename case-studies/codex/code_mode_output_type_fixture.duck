module () where

const {
  .json_array,
  .json_array_empty,
  .json_array_prepend,
  .json_bool,
  .json_object,
  .json_object_empty,
  .json_object_prepend,
  .json_string,
} = import "duck:prelude/json/values" ();
const { .materialize_code_mode_output_type } = import "./code_mode_output_type.duck" ();

const typed_schema: Text -> Json = name => json_object(
  json_object_prepend("type", json_string name, json_object_empty())
);

let string_schema = typed_schema "string";
let boolean_schema = typed_schema "boolean";
let score = 0;

let ok_properties = json_object_prepend("ok", boolean_schema, json_object_empty());
let ok_required = json_array_prepend(json_string "ok", json_array_empty());
let output_members = json_object_prepend(
  "type",
  json_string "object",
  json_object_prepend(
    "properties",
    json_object ok_properties,
    json_object_prepend("required", json_array ok_required, json_object_empty()),
  ),
);
if materialize_code_mode_output_type(json_object output_members) == "{ ok: boolean; }" { score = score + 1 }

let content_members = json_object_prepend(
  "type",
  json_string "array",
  json_object_prepend(
    "items",
    json_object(json_object_prepend("type", json_string "object", json_object_empty())),
    json_object_empty(),
  ),
);
let echo_properties = json_object_prepend("echo", string_schema, json_object_empty());
let echo_required = json_array_prepend(json_string "echo", json_array_empty());
let structured_members = json_object_prepend(
  "type",
  json_string "object",
  json_object_prepend(
    "properties",
    json_object echo_properties,
    json_object_prepend(
      "required",
      json_array echo_required,
      json_object_prepend("additionalProperties", json_bool false, json_object_empty()),
    ),
  ),
);
let mcp_properties = json_object_prepend(
  "content",
  json_object content_members,
  json_object_prepend(
    "structuredContent",
    json_object structured_members,
    json_object_prepend(
      "isError",
      boolean_schema,
      json_object_prepend(
        "_meta",
        json_object(json_object_prepend("type", json_string "object", json_object_empty())),
        json_object_empty(),
      ),
    ),
  ),
);
let mcp_output = json_object(
  json_object_prepend(
    "type",
    json_string "object",
    json_object_prepend("properties", json_object mcp_properties, json_object_empty()),
  )
);
if materialize_code_mode_output_type mcp_output == "CallToolResult<{ echo: string; }>" { score = score + 10 }

let raw_mcp_properties = json_object_prepend(
  "content",
  json_object content_members,
  json_object_prepend(
    "isError",
    boolean_schema,
    json_object_prepend(
      "_meta",
      json_object(json_object_prepend("type", json_string "object", json_object_empty())),
      json_object_empty(),
    ),
  ),
);
let raw_mcp_output = json_object(
  json_object_prepend(
    "type",
    json_string "object",
    json_object_prepend("properties", json_object raw_mcp_properties, json_object_empty()),
  )
);
if materialize_code_mode_output_type raw_mcp_output == "CallToolResult" { score = score + 100 }

return { .score = score };
