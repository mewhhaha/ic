module () where

const {} = import "./audio_types.duck" ();

const ascii_lowercase = (byte: I32) => {
  if byte >= 65 && byte <= 90 { byte + 32 } else { byte }
};

const classify_audio_format: Text -> I32 = mime => {
  let inspected_mime = @append(mime, "");
  let mime_length = @len inspected_mime;
  let has_audio_prefix = mime_length >= 6;

  if has_audio_prefix {
    has_audio_prefix = ascii_lowercase(@get(inspected_mime, 0)) == 97 && ascii_lowercase(
      @get(inspected_mime, 1)
    ) == 117 && ascii_lowercase(@get(inspected_mime, 2)) == 100 && ascii_lowercase(
      @get(inspected_mime, 3)
    ) == 105 && ascii_lowercase(@get(inspected_mime, 4)) == 111 && @get(inspected_mime, 5) == 47
  }

  let code = if !(has_audio_prefix) {
    5
  } else if mime_length == 9 {
    let first = ascii_lowercase(@get(inspected_mime, 6));
    let second = ascii_lowercase(@get(inspected_mime, 7));
    let third = ascii_lowercase(@get(inspected_mime, 8));
    if first == 119 && second == 97 && third == 118 {
      0
    } else if first == 109 && second == 112 && third == 51 {
      1
    } else if first == 109 && second == 112 && third == 52 {
      2
    } else if first == 109 && second == 52 && third == 97 {
      2
    } else if first == 111 && second == 103 && third == 103 {
      4
    } else {
      5
    }
  } else if mime_length == 10 {
    let first = ascii_lowercase(@get(inspected_mime, 6));
    let second = ascii_lowercase(@get(inspected_mime, 7));
    let third = ascii_lowercase(@get(inspected_mime, 8));
    let fourth = ascii_lowercase(@get(inspected_mime, 9));
    if first == 119 && second == 97 && third == 118 && fourth == 101 {
      0
    } else if first == 109 && second == 112 && third == 101 && fourth == 103 {
      1
    } else if first == 119 && second == 101 && third == 98 && fourth == 109 {
      3
    } else {
      5
    }
  } else if mime_length == 11 {
    let first = ascii_lowercase(@get(inspected_mime, 6));
    let second = ascii_lowercase(@get(inspected_mime, 7));
    let third = ascii_lowercase(@get(inspected_mime, 8));
    let fourth = ascii_lowercase(@get(inspected_mime, 9));
    let fifth = ascii_lowercase(@get(inspected_mime, 10));
    if first == 120 && second == 45 && third == 119 && fourth == 97 && fifth == 118 {
      0
    } else if first == 120 && second == 45 && third == 109 && fourth == 52 && fifth == 97 {
      2
    } else {
      5
    }
  } else if mime_length == 14 {
    let suffix_matches = ascii_lowercase(@get(inspected_mime, 6)) == 118 && ascii_lowercase(
      @get(inspected_mime, 7)
    ) == 110 && ascii_lowercase(@get(inspected_mime, 8)) == 100 && @get(inspected_mime, 9) == 46 && ascii_lowercase(
      @get(inspected_mime, 10)
    ) == 119 && ascii_lowercase(@get(inspected_mime, 11)) == 97 && ascii_lowercase(
      @get(inspected_mime, 12)
    ) == 118 && ascii_lowercase(@get(inspected_mime, 13)) == 101;
    if suffix_matches {
      0
    } else {
      5
    }
  } else {
    5
  };

  code
};

return { .classify_audio_format };
