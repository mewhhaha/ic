module () where

const { .text_append, .text_starts_with } = import "duck:prelude/functional" ();
const {} = import "./cli_types.duck" ();

type AppServerToolArgs = CodexCliArgs
type AppServerToolTextOption = CodexCliTextOption
type AppServerToolCommandResult = CodexAppServerCommandResult
type AppServerGenerateFacts = CodexAppServerGenerateFacts
type AppServerGenerateFactsResult = Result Text AppServerGenerateFacts
type AppServerGenerateTsOptions = CodexAppServerGenerateTsOptions
type AppServerGenerateJsonOptions = CodexAppServerGenerateJsonOptions

type AppServerGenerateTarget =
  | `GenerateTypeScript Unit
  | `GenerateJsonSchema Unit
  | `GenerateInternalJsonSchema Unit

const parse_app_server_daemon: AppServerToolArgs -> AppServerToolCommandResult = (
  args: AppServerToolArgs ) => {
  if let `Cons node = args {
    let [operation, remaining] = node;
    if operation == "bootstrap" {
      if let `Nil () = remaining {
        `Ok (`ManageAppServerDaemon (`AppServerDaemonBootstrap false))
      } else if let `Cons option_node = remaining {
        let [option, tail] = option_node;
        if option == "--remote-control" {
          if let `Nil () = tail {
            `Ok (`ManageAppServerDaemon (`AppServerDaemonBootstrap true))
          } else {
            `Err "app-server daemon bootstrap accepts only --remote-control"
          }
        } else {
          `Err (text_append("unknown app-server daemon bootstrap option: ", option))
        }
      } else {
        `Err "app-server daemon bootstrap arguments have an unknown shape"
      }
    } else if let `Nil () = remaining {
      if operation == "start" {
        `Ok (`ManageAppServerDaemon (`AppServerDaemonStart ()))
      } else if operation == "restart" {
        `Ok (`ManageAppServerDaemon (`AppServerDaemonRestart ()))
      } else if operation == "enable-remote-control" {
        `Ok (`ManageAppServerDaemon (`AppServerDaemonEnableRemoteControl ()))
      } else if operation == "disable-remote-control" {
        `Ok (`ManageAppServerDaemon (`AppServerDaemonDisableRemoteControl ()))
      } else if operation == "stop" {
        `Ok (`ManageAppServerDaemon (`AppServerDaemonStop ()))
      } else if operation == "version" {
        `Ok (`ManageAppServerDaemon (`AppServerDaemonVersion ()))
      } else if operation == "pid-update-loop" {
        `Ok (`ManageAppServerDaemon (`AppServerDaemonPidUpdateLoop ()))
      } else {
        `Err (text_append("unknown app-server daemon operation: ", operation))
      }
    } else {
      `Err (text_append(text_append("app-server daemon ", operation), " does not accept arguments"))
    }
  } else {
    `Err "app-server daemon requires an operation"
  }
};

let rec scan_app_server_proxy_from: [AppServerToolArgs, AppServerToolTextOption] -> AppServerToolCommandResult = (
    args: AppServerToolArgs,
    socket_path: AppServerToolTextOption,
  ) => {
    if let `Cons node = args {
      let [argument, tail] = node;
      if argument == "--sock" {
        if let `Cons value_node = tail {
          let [value, remaining] = value_node;
          scan_app_server_proxy_from(remaining, `Some value)
        } else {
          `Err "missing value for --sock"
        }
      } else {
        `Err (text_append("unknown app-server proxy option: ", argument))
      }
    } else {
      `Ok (`ProxyAppServer socket_path)
    }
  };

let parse_app_server_proxy: AppServerToolArgs -> AppServerToolCommandResult = (
  args: AppServerToolArgs ) => {
  scan_app_server_proxy_from(args, `None ())
};

let rec scan_app_server_generate_from: [
  AppServerToolArgs,
  AppServerGenerateFacts,
  AppServerGenerateTarget,
] -> AppServerGenerateFactsResult = (
  args: AppServerToolArgs,
  facts: AppServerGenerateFacts,
  target: AppServerGenerateTarget,
) => {
  if let `Cons node = args {
    let [argument, tail] = node;
    if argument == "--out" || argument == "-o" {
      if let `Cons value_node = tail {
        let [value, remaining] = value_node;
        scan_app_server_generate_from(remaining, facts <& { .out_dir = `Some value }, target)
      } else {
        `Err (text_append("missing value for ", argument))
      }
    } else if argument == "--prettier" || argument == "-p" {
      if let `GenerateTypeScript () = target {
        if let `Cons value_node = tail {
          let [value, remaining] = value_node;
          scan_app_server_generate_from(remaining, facts <& { .prettier = `Some value }, target)
        } else {
          `Err (text_append("missing value for ", argument))
        }
      } else {
        `Err "--prettier is only valid for app-server generate-ts"
      }
    } else if argument == "--experimental" {
      if let `GenerateInternalJsonSchema () = target {
        `Err "--experimental is not valid for app-server generate-internal-json-schema"
      } else {
        scan_app_server_generate_from(tail, facts <& { .experimental = true }, target)
      }
    } else if text_starts_with(argument, "-") {
      `Err (text_append("unknown app-server generation option: ", argument))
    } else {
      `Err "app-server generation commands do not accept positional arguments"
    }
  } else {
    `Ok facts
  }
};

let parse_app_server_generate: [AppServerGenerateTarget, AppServerToolArgs] -> AppServerToolCommandResult = (
    target: AppServerGenerateTarget,
    args: AppServerToolArgs,
  ) => {
    let initial: AppServerGenerateFacts = [
      .out_dir = `None (),
      .prettier = `None (),
      .experimental = false,
    ];
    let scanned: AppServerGenerateFactsResult = scan_app_server_generate_from(args, initial, target);
    if let `Err message = scanned {
      `Err message
    } else if let `Ok facts = scanned {
      if let `Some out_dir = facts.out_dir {
        if let `GenerateTypeScript () = target {
          let options: AppServerGenerateTsOptions = [
            .out_dir = out_dir,
            .prettier = facts.prettier,
            .experimental = facts.experimental,
          ];
          `Ok (`GenerateAppServerTs options);
        } else if let `GenerateJsonSchema () = target {
          let options: AppServerGenerateJsonOptions = [
            .out_dir = out_dir,
            .experimental = facts.experimental,
          ];
          `Ok (`GenerateAppServerJsonSchema options);
        } else if let `GenerateInternalJsonSchema () = target {
          `Ok (`GenerateAppServerInternalJsonSchema out_dir)
        } else {
          `Err "app-server generation target has an unknown shape"
        }
      } else {
        `Err "app-server generation command requires --out"
      }
    } else {
      `Err "app-server generation scanner returned an unknown result"
    }
  };

let parse_app_server_tools: [Text, AppServerToolArgs] -> AppServerToolCommandResult = (
  command: Text,
  args: AppServerToolArgs,
) => {
  if command == "daemon" {
    parse_app_server_daemon args
  } else if command == "proxy" {
    parse_app_server_proxy args
  } else if command == "generate-ts" {
    parse_app_server_generate(`GenerateTypeScript (), args)
  } else if command == "generate-json-schema" {
    parse_app_server_generate(`GenerateJsonSchema (), args)
  } else if command == "generate-internal-json-schema" {
    parse_app_server_generate(`GenerateInternalJsonSchema (), args)
  } else {
    `Err (text_append("unknown app-server tool command: ", command))
  }
};

return {
  .parse_app_server_daemon,
  .parse_app_server_generate,
  .parse_app_server_proxy,
  .parse_app_server_tools,
};
