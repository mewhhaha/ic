module () where

const { .json_object_get, .parse_json_document } = import "duck:prelude/json" ();
const {} = import "./agent_job_spawn_types.duck" ();

type AgentJobSpawnNumericArgs = AgentJobSpawnDecodedArgs
type AgentJobSpawnNumericOptionalResult = AgentJobOptionalTextResult
type AgentJobSpawnNumericResult = AgentJobSpawnDecodeResult

let decode_agent_job_spawn_numeric_options: [Text, AgentJobSpawnNumericArgs] -> AgentJobSpawnNumericResult = (
    document: Text,
    base: AgentJobSpawnNumericArgs,
  ) => {
    let parsed = parse_json_document document;
    if let `Ok value_and_position = parsed {
      let [value, _] = value_and_position;
      if let `Object object = value {
        let concurrency_lookup = json_object_get("max_concurrency", object);
        let decoded_concurrency: AgentJobSpawnNumericOptionalResult = if let `Found field = concurrency_lookup {
            if let `Number max_concurrency = field {
              `AgentJobTextDecoded (`Some max_concurrency)
            } else if let `Null () = field {
              `AgentJobTextDecoded (`None ())
            } else {
              `AgentJobTextDecodeFailed "max_concurrency"
            }
          } else {
            `AgentJobTextDecoded (`None ())
          };
        if let `AgentJobTextDecodeFailed _ = decoded_concurrency {
          `SpawnDecodeFailed "max_concurrency must be a number"
        } else if let `AgentJobTextDecoded max_concurrency = decoded_concurrency {
          let workers_lookup = json_object_get("max_workers", object);
          let decoded_workers: AgentJobSpawnNumericOptionalResult = if let `Found field = workers_lookup {
              if let `Number max_workers = field {
                `AgentJobTextDecoded (`Some max_workers)
              } else if let `Null () = field {
                `AgentJobTextDecoded (`None ())
              } else {
                `AgentJobTextDecodeFailed "max_workers"
              }
            } else {
              `AgentJobTextDecoded (`None ())
            };
          if let `AgentJobTextDecodeFailed _ = decoded_workers {
            `SpawnDecodeFailed "max_workers must be a number"
          } else if let `AgentJobTextDecoded max_workers = decoded_workers {
            let runtime_lookup = json_object_get("max_runtime_seconds", object);
            let decoded_runtime: AgentJobSpawnNumericOptionalResult = if let `Found field = runtime_lookup {
                if let `Number max_runtime_seconds = field {
                  `AgentJobTextDecoded (`Some max_runtime_seconds)
                } else if let `Null () = field {
                  `AgentJobTextDecoded (`None ())
                } else {
                  `AgentJobTextDecodeFailed "max_runtime_seconds"
                }
              } else {
                `AgentJobTextDecoded (`None ())
              };
            if let `AgentJobTextDecodeFailed _ = decoded_runtime {
              `SpawnDecodeFailed "max_runtime_seconds must be a number"
            } else if let `AgentJobTextDecoded max_runtime_seconds = decoded_runtime {
              let args: AgentJobSpawnNumericArgs = [
                .csv_path = base.csv_path,
                .instruction = base.instruction,
                .id_column = base.id_column,
                .output_path = base.output_path,
                .output_schema_json = base.output_schema_json,
                .max_concurrency = max_concurrency,
                .max_workers = max_workers,
                .max_runtime_seconds = max_runtime_seconds,
              ];
              `SpawnDecoded args;
            } else {
              `SpawnDecodeFailed "max_runtime_seconds decoder returned no result"
            }
          } else {
            `SpawnDecodeFailed "max_workers decoder returned no result"
          }
        } else {
          `SpawnDecodeFailed "max_concurrency decoder returned no result"
        }
      } else {
        `SpawnDecodeFailed "failed to parse function arguments: expected an object"
      }
    } else {
      `SpawnDecodeFailed "failed to parse function arguments: invalid JSON"
    }
  };

return { .decode_agent_job_spawn_numeric_options };
