module () where

const {} = import "./request_user_input_types.duck" ();
const { .plan_request_user_input } = import "./request_user_input_policy.duck" ();

type FixtureArgs = RequestUserInputArgs
type FixtureOption = RequestUserInputQuestionOption
type FixtureOptionNode = RequestUserInputQuestionOptionNode
type FixtureOptions = RequestUserInputQuestionOptions
type FixtureQuestion = RequestUserInputQuestion
type FixtureQuestionNode = RequestUserInputQuestionNode
type FixtureQuestions = RequestUserInputQuestions

let root_only_questions: FixtureQuestions = `Cons (
  [
    [
      .id = "confirm",
      .header = "Confirm",
      .question = "Proceed?",
      .is_other = false,
      .is_secret = false,
      .options = `Present (
        `Cons (
          [[.label = "Continue", .description = "Proceed."] as FixtureOption, `Nil ()] as FixtureOptionNode
        )
      ),
    ] as FixtureQuestion,
    `Nil (),
  ] as FixtureQuestionNode
);
let root_only_args: FixtureArgs = [
  .questions = root_only_questions,
  .auto_resolution = `NoAutoResolution (),
];
let unavailable_questions: FixtureQuestions = `Cons (
  [
    [
      .id = "confirm",
      .header = "Confirm",
      .question = "Proceed?",
      .is_other = false,
      .is_secret = false,
      .options = `Present (
        `Cons (
          [[.label = "Continue", .description = "Proceed."] as FixtureOption, `Nil ()] as FixtureOptionNode
        )
      ),
    ] as FixtureQuestion,
    `Nil (),
  ] as FixtureQuestionNode
);
let unavailable_args: FixtureArgs = [
  .questions = unavailable_questions,
  .auto_resolution = `NoAutoResolution (),
];
let prompt_questions: FixtureQuestions = `Cons (
  [
    [
      .id = "confirm",
      .header = "Confirm",
      .question = "Proceed?",
      .is_other = false,
      .is_secret = false,
      .options = `Present (
        `Cons (
          [[.label = "Continue", .description = "Proceed."] as FixtureOption, `Nil ()] as FixtureOptionNode
        )
      ),
    ] as FixtureQuestion,
    `Nil (),
  ] as FixtureQuestionNode
);
let prompt_args: FixtureArgs = [
  .questions = prompt_questions,
  .auto_resolution = `NoAutoResolution (),
];
let score = 0;

if let `RejectRequest message = plan_request_user_input(false, `Plan (), true, root_only_args) {
  if message == "request_user_input can only be used by the root thread" { score = score + 1 }
}
if let `RejectRequest message = plan_request_user_input(true, `Default (), false,
  unavailable_args) {
    if message == "request_user_input is unavailable in Default mode" { score = score + 10 }
  }
if let `PromptUser normalized = plan_request_user_input(true, `Default (), true, prompt_args) {
  if let `Cons node = normalized.questions {
    let [normalized_question, _] = node;
    if normalized_question.is_other { score = score + 100 }
  }
}

return { .score = score };
