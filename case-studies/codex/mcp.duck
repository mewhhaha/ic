module () where

const { .list } = import "duck:prelude/functional" ();
const tool_types_module = import "./tool_types.duck";
const mcp_types_module = import "./mcp_types.duck";

type McpTextList = McpTexts
type McpToolValue = McpTool
type McpToolValues = McpTools
type McpRuntime = McpToolRuntime
type McpRuntimes = McpToolRuntimes
type McpVisibility = McpToolVisibility
type McpAnnotations = McpToolAnnotations
type McpBoolValue = McpBoolOption
type McpMode = McpApprovalMode
type McpDecision = McpApprovalDecision
type McpExposure = ToolExposure

const texts = comptime list Text;
const tools = comptime list McpToolValue;
const runtimes = comptime list McpRuntime;

const model_visible = (visibility: McpVisibility) => {
  if let `Model () = visibility {
    true
  } else if let `ModelAndApp () = visibility {
    true
  } else {
    false
  }
};

const build_mcp_tool_runtimes = (
  available: McpToolValues,
  allowed_connectors: McpTextList,
  search_tool_enabled: Bool,
) => {
  let exposure: McpExposure = if search_tool_enabled { `Deferred () } else { `Direct () };
  let current = available;
  let selected = runtimes.empty();
  let done = false;

  loop {
    if let `Cons node = current {
      let [tool, tail] = node;
      let [server_name, _, _, _, connector_id, _, visibility, enabled, _] = tool;
      let app_tool = server_name == "codex_apps";
      let exposed = model_visible visibility && enabled;

      if app_tool {
        let allowed = if let `Some requested = connector_id {
          texts.any(allowed_connectors, (candidate: Text) => candidate == requested)
        } else {
          false
        };
        exposed = exposed && allowed
      }

      if exposed {
        let runtime: McpRuntime = [tool, exposure];
        selected = runtimes.prepend(runtime, selected)
      }

      current = tail
    } else {
      done = true
    }

    if done { break; }
  }

  runtimes.reverse(selected)
};

const bool_option_is_true = (value: McpBoolValue) => {
  if let `Some enabled = value { enabled } else { false }
};

const requires_mcp_tool_approval: [McpAnnotations, McpMode, Bool] -> Bool = (
  annotations: McpAnnotations,
  mode: McpMode,
  full_access: Bool,
) => {
  let [read_only, destructive, open_world] = annotations;

  if full_access {
    false
  } else if let `Never () = mode {
    false
  } else if let `Prompt () = mode {
    true
  } else if let `Writes () = mode {
    !(bool_option_is_true read_only)
  } else {
    !(bool_option_is_true read_only) || bool_option_is_true destructive || bool_option_is_true open_world
  }
};

const normalize_mcp_approval_decision: [McpDecision, McpMode] -> McpDecision = (
  decision: McpDecision,
  mode: McpMode,
) => {
  let prompting = if let `Prompt () = mode { true } else if let `Writes () = mode { true } else {
    false };

  if prompting {
    if let `AcceptForSession () = decision {
      `Accept ()
    } else if let `AcceptAndRemember () = decision {
      `Accept ()
    } else {
      decision
    }
  } else {
    decision
  }
};

return {
  .model_visible,
  .build_mcp_tool_runtimes,
  .requires_mcp_tool_approval,
  .normalize_mcp_approval_decision,
};
