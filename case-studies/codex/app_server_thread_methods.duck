    `MethodError "thread/compact/start.params must be an object"
  }
};

const decode_metadata_git_field: [ThreadMethodJsonObject, Text] -> ThreadMethodTextPatchResult = (
  object: ThreadMethodJsonObject,
  key: Text,
) => {
  let lookup: ThreadMethodJsonLookup = json_object_get(key, object);

  if let `Found value = lookup {
    if let `Null () = value {
      `Ok (`Clear ())
    } else if let `String text = value {
      let trimmed = text_trim_ascii_whitespace text;
      if trimmed == "" {
        `Err ("gitInfo." <> key <> " must not be empty")
      } else {
        `Ok (`Set trimmed)
      }
    } else {
      `Err ("thread/metadata/update.params.gitInfo." <> key <> " must be a string or null")
    }
  } else {
    `Ok (`Keep ())
  }
};

const decode_thread_metadata_update: ThreadMethodJson -> ThreadMethodDecodeResult = (
  params: ThreadMethodJson ) => {
  if let `Object object = params {
    let thread_id = required_text(object, "threadId", "thread/metadata/update.params");
    let git_info_lookup: ThreadMethodJsonLookup = json_object_get("gitInfo", object);

    if let `Err reason = thread_id {
      `MethodError reason
    } else if let `Found git_info_json = git_info_lookup {
      if let `Object git_info = git_info_json {
        let sha = decode_metadata_git_field(git_info, "sha");
        let branch = decode_metadata_git_field(git_info, "branch");
        let origin_url = decode_metadata_git_field(git_info, "originUrl");

        if let `Err reason = sha {
          `MethodError reason
        } else if let `Err reason = branch {
          `MethodError reason
        } else if let `Err reason = origin_url {
          `MethodError reason
        } else if let `Ok sha_patch = sha {
          if let `Ok branch_patch = branch {
            if let `Ok origin_url_patch = origin_url {
              let has_patch = false;
              if let `Set _ = sha_patch { has_patch = true }
              if let `Clear () = sha_patch { has_patch = true }
              if let `Set _ = branch_patch { has_patch = true }
              if let `Clear () = branch_patch { has_patch = true }
              if let `Set _ = origin_url_patch { has_patch = true }
              if let `Clear () = origin_url_patch { has_patch = true }

              if has_patch {
                if let `Ok id = thread_id {
                  let patch: ThreadMethodMetadataGitInfoPatch = [
                    sha_patch,
                    branch_patch,
                    origin_url_patch,
                  ];
                  let decoded: ThreadMethodMetadataUpdateParams = [id, patch];
                  `MethodOk (`ThreadMetadataUpdate decoded);
                } else {
                  `MethodError "thread/metadata/update.params.threadId could not be decoded"
                }
              } else {
                `MethodError "gitInfo must include at least one field"
              }
            } else { `MethodError "thread/metadata/update.params.gitInfo.originUrl could not be decoded" }
          } else { `MethodError "thread/metadata/update.params.gitInfo.branch could not be decoded" }
        } else {
          `MethodError "thread/metadata/update.params.gitInfo.sha could not be decoded"
        }
      } else if let `Null () = git_info_json {
        `MethodError "gitInfo must include at least one field"
      } else {
        `MethodError "thread/metadata/update.params.gitInfo must be an object or null"
      }
    } else {
      `MethodError "gitInfo must include at least one field"
    }
  } else {
    `MethodError "thread/metadata/update.params must be an object"
  }
};

const decode_thread_settings_update: ThreadMethodJson -> ThreadMethodDecodeResult = (
  params: ThreadMethodJson ) => {
  if let `Object object = params {
    let thread_id = required_text(object, "threadId", "thread/settings/update.params");
    let cwd = optional_text(object, "cwd", "thread/settings/update.params");
    let permissions = optional_text(object, "permissions", "thread/settings/update.params");
    let model = optional_text(object, "model", "thread/settings/update.params");
    let effort = optional_text(object, "effort", "thread/settings/update.params");
    let summary = optional_text(object, "summary", "thread/settings/update.params");
    let personality = optional_text(object, "personality", "thread/settings/update.params");
    let approval_policy: ThreadMethodJsonOption = optional_json(object, "approvalPolicy");
    let approvals_reviewer: ThreadMethodJsonOption = optional_json(object, "approvalsReviewer");
    let sandbox_policy: ThreadMethodJsonOption = optional_json(object, "sandboxPolicy");
    let collaboration_mode: ThreadMethodJsonOption = optional_json(object, "collaborationMode");
    let service_tier_lookup: ThreadMethodJsonLookup = json_object_get("serviceTier", object);
    let service_tier: ThreadMethodTextPatchResult = if let `Found tier_json = service_tier_lookup {
      if let `Null () = tier_json {
        `Ok (`Clear ())
      } else if let `String tier = tier_json {
        `Ok (`Set tier)
      } else {
        `Err "thread/settings/update.params.serviceTier must be a string or null"
      }
    } else {
      `Ok (`Keep ())
    };

    if let `Err reason = thread_id {
      `MethodError reason
    } else if let `Err reason = cwd {
      `MethodError reason
    } else if let `Err reason = permissions {
      `MethodError reason
    } else if let `Err reason = model {
      `MethodError reason
    } else if let `Err reason = service_tier {
      `MethodError reason
    } else if let `Err reason = effort {
      `MethodError reason
    } else if let `Err reason = summary {
      `MethodError reason
    } else if let `Err reason = personality {
      `MethodError reason
    } else {
      let conflicting_permissions = false;
      if let `Some _ = sandbox_policy {
        if let `Ok permission_value = permissions {
          if let `Some _ = permission_value { conflicting_permissions = true }
        }
      }

      if conflicting_permissions {
        `MethodError "`permissions` cannot be combined with `sandboxPolicy`"
      } else if let `Ok id = thread_id {
        if let `Ok cwd_value = cwd {
          if let `Ok permission_value = permissions {
            if let `Ok model_value = model {
              if let `Ok tier_patch = service_tier {
                if let `Ok effort_value = effort {
                  if let `Ok summary_value = summary {
                    if let `Ok personality_value = personality {
                      let has_update = json_field_is_non_null(object,
                        "cwd") || json_field_is_non_null(
                          object,
                          "approvalPolicy"
                        ) || json_field_is_non_null(object, "approvalsReviewer") || json_field_is_non_null(
                        object,
                        "sandboxPolicy",
                      ) || json_field_is_non_null(object, "permissions") || json_field_is_non_null(
                        object,
                        "model",
                      ) || json_field_is_present(object, "serviceTier") || json_field_is_non_null(
                        object,
                        "effort",
                      ) || json_field_is_non_null(object, "summary") || json_field_is_non_null(
                        object,
                        "collaborationMode",
                      ) || json_field_is_non_null(object, "personality");
                      let decoded: ThreadMethodSettingsUpdateParams = [
                        id,
                        cwd_value,
                        approval_policy,
                        approvals_reviewer,
                        sandbox_policy,
                        permission_value,
                        model_value,
                        tier_patch,
                        effort_value,
                        summary_value,
                        collaboration_mode,
                        personality_value,
                        has_update,
                        params,
                      ];
                      `MethodOk (`ThreadSettingsUpdate decoded);
                    } else { `MethodError "thread/settings/update.params.personality could not be decoded"
                    }
                  } else { `MethodError "thread/settings/update.params.summary could not be decoded" }
                } else { `MethodError "thread/settings/update.params.effort could not be decoded" }
              } else { `MethodError "thread/settings/update.params.serviceTier could not be decoded" }
            } else { `MethodError "thread/settings/update.params.model could not be decoded" }
          } else { `MethodError "thread/settings/update.params.permissions could not be decoded" }
        } else { `MethodError "thread/settings/update.params.cwd could not be decoded" }
      } else {
        `MethodError "thread/settings/update.params.threadId could not be decoded"
      }
    }
  } else {
    `MethodError "thread/settings/update.params must be an object"
  }
};

const decode_page_size: [ThreadMethodJsonObject, Text] -> ThreadMethodPageSizeResult = (
  object: ThreadMethodJsonObject,
  context: Text,
) => {
  let lookup: ThreadMethodJsonLookup = json_object_get("limit", object);

  if let `Found value = lookup {
    if let `Null () = value {
      `Ok 25
    } else if let `Number number = value {
      let parsed = parse_u32_decimal number;
      if let `Ok page_size = parsed {
        if page_size < 1i64 {
          `Ok 1
        } else if page_size > 100i64 {
          `Ok 100
        } else {
          `Ok (unsafe_i32_wrap_i64 page_size)
        }
      } else if let `Err reason = parsed {
        `Err (context <> ".limit " <> reason)
      } else {
        `Err (context <> ".limit could not be decoded")
      }
    } else {
      `Err (context <> ".limit must be a non-negative integer or null")
    }
  } else {
    `Ok 25
  }
};

const decode_page_sort_direction: [ThreadMethodJsonObject, Text, ThreadMethodSortDirection] -> ThreadMethodSortDirectionResult = (
    object: ThreadMethodJsonObject,
    context: Text,
    fallback: ThreadMethodSortDirection,
  ) => {
    let decoded = optional_text(object, "sortDirection", context);

    if let `Err reason = decoded {
      `Err reason
    } else if let `Ok value = decoded {
      if let `Some direction = value {
        if direction == "asc" {
          `Ok (`Ascending ())
        } else if direction == "desc" {
          `Ok (`Descending ())
        } else {
          `Err (context <> ".sortDirection has unknown value " <> direction)
        }
      } else {
        `Ok fallback
      }
    } else {
      `Err (context <> ".sortDirection could not be decoded")
    }
  };

const decode_turn_items_view: ThreadMethodJsonObject -> ThreadMethodItemsViewResult = (
  object: ThreadMethodJsonObject ) => {
  let decoded = optional_text(object, "itemsView", "thread/turns/list.params");

  if let `Err reason = decoded {
    `Err reason
  } else if let `Ok value = decoded {
    if let `Some view = value {
      if view == "notLoaded" {
        `Ok (`NotLoaded ())
      } else if view == "summary" {
        `Ok (`Summary ())
      } else if view == "full" {
        `Ok (`Full ())
      } else {
        `Err ("thread/turns/list.params.itemsView has unknown value " <> view)
      }
    } else {
      `Ok (`Summary ())
    }
  } else {
    `Err "thread/turns/list.params.itemsView could not be decoded"
  }
};

const decode_thread_turns_list: ThreadMethodJson -> ThreadMethodDecodeResult = (
  params: ThreadMethodJson ) => {
  if let `Object object = params {
    let thread_id = required_text(object, "threadId", "thread/turns/list.params");
    let cursor = optional_text(object, "cursor", "thread/turns/list.params");
    let page_size = decode_page_size(object, "thread/turns/list.params");
    let fallback: ThreadMethodSortDirection = `Descending ();
    let direction = decode_page_sort_direction(object, "thread/turns/list.params", fallback);
    let items_view = decode_turn_items_view object;

    if let `Err reason = thread_id {
      `MethodError reason
    } else if let `Err reason = cursor {
      `MethodError reason
    } else if let `Err reason = page_size {
      `MethodError reason
    } else if let `Err reason = direction {
      `MethodError reason
    } else if let `Err reason = items_view {
      `MethodError reason
    } else if let `Ok id = thread_id {
      if let `Ok cursor_value = cursor {
        if let `Ok page_size_value = page_size {
          if let `Ok direction_value = direction {
            if let `Ok items_view_value = items_view {
              let decoded: ThreadMethodTurnsListParams = [
                id,
                cursor_value,
                page_size_value,
                direction_value,
                items_view_value,
              ];
              `MethodOk (`ThreadTurnsList decoded);
            } else { `MethodError "thread/turns/list.params.itemsView could not be decoded" }
          } else { `MethodError "thread/turns/list.params.sortDirection could not be decoded" }
        } else { `MethodError "thread/turns/list.params.limit could not be decoded" }
      } else { `MethodError "thread/turns/list.params.cursor could not be decoded" }
    } else {
      `MethodError "thread/turns/list.params.threadId could not be decoded"
    }
  } else {
    `MethodError "thread/turns/list.params must be an object"
  }
};

const decode_thread_items_list: ThreadMethodJson -> ThreadMethodDecodeResult = (
  params: ThreadMethodJson ) => {
  if let `Object object = params {
    let thread_id = required_text(object, "threadId", "thread/items/list.params");
    let turn_id = optional_text(object, "turnId", "thread/items/list.params");
    let cursor = optional_text(object, "cursor", "thread/items/list.params");
    let page_size = decode_page_size(object, "thread/items/list.params");
    let fallback: ThreadMethodSortDirection = `Ascending ();
    let direction = decode_page_sort_direction(object, "thread/items/list.params", fallback);

    if let `Err reason = thread_id {
      `MethodError reason
    } else if let `Err reason = turn_id {
      `MethodError reason
    } else if let `Err reason = cursor {
      `MethodError reason
    } else if let `Err reason = page_size {
      `MethodError reason
    } else if let `Err reason = direction {
      `MethodError reason
    } else if let `Ok id = thread_id {
      if let `Ok turn_id_value = turn_id {
        if let `Ok cursor_value = cursor {
          if let `Ok page_size_value = page_size {
            if let `Ok direction_value = direction {
              let decoded: ThreadMethodItemsListParams = [
                id,
                turn_id_value,
                cursor_value,
                page_size_value,
                direction_value,
              ];
              `MethodOk (`ThreadItemsList decoded);
            } else { `MethodError "thread/items/list.params.sortDirection could not be decoded" }
          } else { `MethodError "thread/items/list.params.limit could not be decoded" }
        } else { `MethodError "thread/items/list.params.cursor could not be decoded" }
      } else { `MethodError "thread/items/list.params.turnId could not be decoded" }
    } else {
      `MethodError "thread/items/list.params.threadId could not be decoded"
    }
  } else {
    `MethodError "thread/items/list.params must be an object"
  }
};

return {
  .decode_thread_start,
  .decode_thread_resume,
  .decode_thread_fork,
  .decode_thread_archive,
  .decode_thread_unarchive,
  .decode_thread_delete,
  .decode_thread_unsubscribe,
