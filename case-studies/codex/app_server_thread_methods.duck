  params: ThreadMethodJson ) => {
  if let `Object object = params {
    let thread_id = required_text(object, "threadId", "thread/compact/start.params");
    if let `Ok value = thread_id { `MethodOk (`ThreadCompactStart value) } else if let `Err reason = thread_id { `MethodError reason } else { `MethodError "thread/compact/start.params.threadId could not be decoded" }
