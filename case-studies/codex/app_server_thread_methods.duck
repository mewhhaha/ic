module () where

const { .json_object_get } = import "duck:prelude/json" ();
const { .text_trim_ascii_whitespace } = import "duck:prelude/functional" ();
const { .unsafe_i32_wrap_i64 } = import "duck:prelude/numeric" ();
const { .parse_u32_decimal } = import "duck:prelude/numeric/parse" ();
const {} = import "./app_server_types.duck" ();

type ThreadMethodJson = AppServerJson
type ThreadMethodJsonObject = JsonObject
type ThreadMethodJsonLookup = JsonLookupResult
type ThreadMethodTextOption = AppServerTextOption
type ThreadMethodBoolOption = AppServerBoolOption
type ThreadMethodJsonOption = AppServerJsonOption
type ThreadMethodHistoryMode = AppServerThreadHistoryMode
type ThreadMethodHistoryModeOption = AppServerThreadHistoryModeOption
type ThreadMethodStartSource = AppServerThreadStartSource
type ThreadMethodStartSourceOption = AppServerThreadStartSourceOption
type ThreadMethodAllowFallback = AppServerAllowProviderFallback
type ThreadMethodRawEvents = AppServerExperimentalRawEvents
type ThreadMethodExcludeTurns = AppServerExcludeTurns
type ThreadMethodThreadPersistence = AppServerThreadPersistence
type ThreadMethodGoalContinuation = AppServerGoalContinuation
type ThreadMethodStartParams = AppServerThreadStartParams
type ThreadMethodResumeParams = AppServerThreadResumeParams
type ThreadMethodForkParams = AppServerThreadForkParams
type ThreadMethodMetadataGitInfoPatch = AppServerThreadMetadataGitInfoPatch
type ThreadMethodMetadataUpdateParams = AppServerThreadMetadataUpdateParams
type ThreadMethodSettingsUpdateParams = AppServerThreadSettingsUpdateParams
type ThreadMethodTurnsListParams = AppServerThreadTurnsListParams
type ThreadMethodItemsListParams = AppServerThreadItemsListParams
type ThreadMethodSortDirection = AppServerSortDirection
type ThreadMethodItemsView = AppServerTurnItemsView
type ThreadMethodDecodeResult = AppServerMethodDecodeResult
type ThreadMethodTextResult = Result Text Text
type ThreadMethodTextOptionResult = Result Text ThreadMethodTextOption
type ThreadMethodBoolOptionResult = Result Text ThreadMethodBoolOption
type ThreadMethodJsonOptionResult = Result Text ThreadMethodJsonOption
type ThreadMethodHistoryModeResult = Result Text ThreadMethodHistoryModeOption
type ThreadMethodStartSourceResult = Result Text ThreadMethodStartSourceOption
type ThreadMethodAllowFallbackResult = Result Text ThreadMethodAllowFallback
type ThreadMethodRawEventsResult = Result Text ThreadMethodRawEvents
type ThreadMethodExcludeTurnsResult = Result Text ThreadMethodExcludeTurns
type ThreadMethodThreadPersistenceResult = Result Text ThreadMethodThreadPersistence
type ThreadMethodGoalContinuationResult = Result Text ThreadMethodGoalContinuation
type ThreadMethodTextPatch = FieldPatch Text
type ThreadMethodTextPatchResult = Result Text ThreadMethodTextPatch
type ThreadMethodPageSizeResult = Result Text I32
type ThreadMethodSortDirectionResult = Result Text ThreadMethodSortDirection
type ThreadMethodItemsViewResult = Result Text ThreadMethodItemsView

const optional_text: [ThreadMethodJsonObject, Text, Text] -> ThreadMethodTextOptionResult = (
  object: ThreadMethodJsonObject,
  key: Text,
  context: Text,
) => {
  let lookup: ThreadMethodJsonLookup = json_object_get(key, object);

  if let `Found value = lookup {
    if let `Null () = value {
      `Ok (`None ())
    } else if let `String text = value {
      `Ok (`Some text)
    } else {
      `Err (context <> "." <> key <> " must be a string or null")
    }
  } else {
    `Ok (`None ())
  }
};

const required_text: [ThreadMethodJsonObject, Text, Text] -> ThreadMethodTextResult = (
  object: ThreadMethodJsonObject,
  key: Text,
  context: Text,
) => {
  let decoded = optional_text(object, key, context);

  if let `Err reason = decoded {
    `Err reason
  } else if let `Ok value = decoded {
    if let `Some text = value {
      `Ok text
    } else {
      `Err (context <> "." <> key <> " is required")
    }
  } else {
    `Err (context <> "." <> key <> " could not be decoded")
  }
};

const optional_path: [ThreadMethodJsonObject, Text] -> ThreadMethodTextOptionResult = (
  object: ThreadMethodJsonObject,
  context: Text,
) => {
  let decoded = optional_text(object, "path", context);

  if let `Ok value = decoded {
    if let `Some path = value {
      if path == "" { `Ok (`None ()) } else { `Ok value }
    } else {
      `Ok value
    }
  } else if let `Err reason = decoded {
    `Err reason
  } else {
    `Err (context <> ".path could not be decoded")
  }
};

const optional_bool: [ThreadMethodJsonObject, Text, Text] -> ThreadMethodBoolOptionResult = (
  object: ThreadMethodJsonObject,
  key: Text,
  context: Text,
) => {
  let lookup: ThreadMethodJsonLookup = json_object_get(key, object);

  if let `Found value = lookup {
    if let `Null () = value {
      `Ok (`None ())
    } else if let `Bool boolean = value {
      `Ok (`Some boolean)
    } else {
      `Err (context <> "." <> key <> " must be a boolean or null")
    }
  } else {
    `Ok (`None ())
  }
};

const optional_json_kind: [ThreadMethodJsonObject, Text, Text, Text] -> ThreadMethodJsonOptionResult = (
    object: ThreadMethodJsonObject,
    key: Text,
    context: Text,
    kind: Text,
  ) => {
    let lookup: ThreadMethodJsonLookup = json_object_get(key, object);

    if let `Found value = lookup {
      if let `Null () = value {
        `Ok (`None ())
      } else if kind == "array" {
        if let `Array _ = value { `Ok (`Some value) } else { `Err (
          context <> "." <> key <> " must be an array or null"
        ) }
      } else {
        if let `Object _ = value { `Ok (`Some value) } else { `Err (
          context <> "." <> key <> " must be an object or null"
        ) }
      }
    } else {
      `Ok (`None ())
    }
  };

const optional_json: [ThreadMethodJsonObject, Text] -> ThreadMethodJsonOption = (
  object: ThreadMethodJsonObject,
  key: Text,
) => {
  let lookup: ThreadMethodJsonLookup = json_object_get(key, object);

  if let `Found value = lookup {
    if let `Null () = value { `None () } else { `Some value }
  } else {
    `None ()
  }
};

const json_field_is_present: [ThreadMethodJsonObject, Text] -> Bool = (
  object: ThreadMethodJsonObject,
  key: Text,
) => {
  let lookup: ThreadMethodJsonLookup = json_object_get(key, object);
  if let `Found _ = lookup { true } else { false }
};

const json_field_is_non_null: [ThreadMethodJsonObject, Text] -> Bool = (
  object: ThreadMethodJsonObject,
  key: Text,
) => {
  let lookup: ThreadMethodJsonLookup = json_object_get(key, object);
  if let `Found value = lookup {
    if let `Null () = value { false } else { true }
  } else {
    false
  }
};

const sandbox_permissions_valid: ThreadMethodJson -> Bool = value => {
  let sandbox_present = false;
  let permissions_present = false;

  if let `Object object = value {
    let sandbox_lookup = json_object_get("sandbox", object);
    let permissions_lookup = json_object_get("permissions", object);
    if let `Found sandbox = sandbox_lookup {
      if let `Null () = sandbox { sandbox_present = false } else { sandbox_present = true }
    }
    if let `Found permissions = permissions_lookup {
      if let `Null () = permissions { permissions_present = false } else { permissions_present = true }
    }
  }

  !(sandbox_present && permissions_present)
};

const decode_history_mode: [ThreadMethodJsonObject, Text] -> ThreadMethodHistoryModeResult = (
  object: ThreadMethodJsonObject,
  context: Text,
) => {
  let decoded = optional_text(object, "historyMode", context);

  if let `Err reason = decoded {
    `Err reason
  } else if let `Ok value = decoded {
    if let `Some mode = value {
      if mode == "legacy" {
        `Ok (`Some (`LegacyHistory ()))
      } else if mode == "paginated" {
        `Ok (`Some (`PaginatedHistory ()))
      } else {
        `Err (context <> ".historyMode has unknown value " <> mode)
      }
    } else {
      `Ok (`None ())
    }
  } else {
    `Err (context <> ".historyMode could not be decoded")
  }
};

const decode_start_source: [ThreadMethodJsonObject, Text] -> ThreadMethodStartSourceResult = (
  object: ThreadMethodJsonObject,
  context: Text,
) => {
  let decoded = optional_text(object, "sessionStartSource", context);

  if let `Err reason = decoded {
    `Err reason
  } else if let `Ok value = decoded {
    if let `Some source = value {
      if source == "startup" {
        `Ok (`Some (`StartupSource ()))
      } else if source == "clear" {
        `Ok (`Some (`ClearSource ()))
      } else {
        `Err (context <> ".sessionStartSource has unknown value " <> source)
      }
    } else {
      `Ok (`None ())
    }
  } else {
    `Err (context <> ".sessionStartSource could not be decoded")
  }
};

let decode_thread_start: ThreadMethodJson -> ThreadMethodDecodeResult = (params: ThreadMethodJson) => {
    if let `Object object = params {
      let model = optional_text(object, "model", "thread/start.params");
      let provider = optional_text(object, "modelProvider", "thread/start.params");
      let allow_fallback_lookup: ThreadMethodJsonLookup = json_object_get(
        "allowProviderModelFallback",
        object,
      );
      let allow_fallback: ThreadMethodAllowFallbackResult = if let `Found fallback_json = allow_fallback_lookup {
          if let `Bool fallback_boolean = fallback_json {
            if fallback_boolean { `Ok (`ProviderFallbackAllowed ()) } else { `Ok (
              `ProviderFallbackDisallowed ()
            ) }
          } else { `Err "thread/start.params.allowProviderModelFallback must be a boolean" }
        } else { `Ok (`ProviderFallbackDisallowed ()) };
      let cwd = optional_text(object, "cwd", "thread/start.params");
      let ephemeral = optional_bool(object, "ephemeral", "thread/start.params");
      let history_mode = decode_history_mode(object, "thread/start.params");
      let start_source = decode_start_source(object, "thread/start.params");
      let raw_events_lookup: ThreadMethodJsonLookup = json_object_get(
        "experimentalRawEvents",
        object,
      );
      let raw_events: ThreadMethodRawEventsResult = if let `Found raw_events_json = raw_events_lookup {
          if let `Bool raw_events_boolean = raw_events_json {
            if raw_events_boolean { `Ok (`RawEventsEnabled ()) } else { `Ok (`RawEventsDisabled ())
            }
          } else { `Err "thread/start.params.experimentalRawEvents must be a boolean" }
        } else { `Ok (`RawEventsDisabled ()) };

      if !sandbox_permissions_valid params {
        `MethodError "`permissions` cannot be combined with `sandbox`"
      } else if let `Err reason = model {
        `MethodError reason
      } else if let `Err reason = provider {
        `MethodError reason
      } else if let `Err reason = allow_fallback {
        `MethodError reason
      } else if let `Err reason = cwd {
        `MethodError reason
      } else if let `Err reason = ephemeral {
        `MethodError reason
      } else if let `Err reason = history_mode {
        `MethodError reason
      } else if let `Err reason = start_source {
        `MethodError reason
      } else if let `Err reason = raw_events {
        `MethodError reason
      } else if let `Ok model_value = model {
        if let `Ok provider_value = provider {
          if let `Ok allow_fallback_value = allow_fallback {
            if let `Ok cwd_value = cwd {
              if let `Ok ephemeral_value = ephemeral {
                if let `Ok history_mode_value = history_mode {
                  if let `Ok start_source_value = start_source {
                    if let `Ok raw_events_value = raw_events {
                      let decoded: ThreadMethodStartParams = [
                        model_value,
                        provider_value,
                        allow_fallback_value,
                        cwd_value,
                        ephemeral_value,
                        history_mode_value,
                        start_source_value,
                        raw_events_value,
                        params,
                      ];
                      `MethodOk (`ThreadStart decoded);
                    } else { `MethodError "thread/start.params.experimentalRawEvents could not be decoded"
                    }
                  } else { `MethodError "thread/start.params.sessionStartSource could not be decoded" }
                } else { `MethodError "thread/start.params.historyMode could not be decoded" }
              } else { `MethodError "thread/start.params.ephemeral could not be decoded" }
            } else { `MethodError "thread/start.params.cwd could not be decoded" }
          } else { `MethodError "thread/start.params.allowProviderModelFallback could not be decoded" }
        } else { `MethodError "thread/start.params.modelProvider could not be decoded" }
      } else {
        `MethodError "thread/start.params.model could not be decoded"
      }
    } else {
      `MethodError "thread/start.params must be an object"
    }
  };

let decode_thread_resume: ThreadMethodJson -> ThreadMethodDecodeResult = (params: ThreadMethodJson) => {
    if let `Object object = params {
      let thread_id = required_text(object, "threadId", "thread/resume.params");
      let history = optional_json_kind(object, "history", "thread/resume.params", "array");
      let path = optional_path(object, "thread/resume.params");
      let model = optional_text(object, "model", "thread/resume.params");
      let provider = optional_text(object, "modelProvider", "thread/resume.params");
      let cwd = optional_text(object, "cwd", "thread/resume.params");
      let exclude_turns_lookup: ThreadMethodJsonLookup = json_object_get("excludeTurns", object);
      let exclude_turns: ThreadMethodExcludeTurnsResult = if let `Found exclude_json = exclude_turns_lookup {
          if let `Bool exclude_boolean = exclude_json {
            if exclude_boolean { `Ok (`TurnsExcluded ()) } else { `Ok (`TurnsIncluded ()) }
          } else { `Err "thread/resume.params.excludeTurns must be a boolean" }
        } else { `Ok (`TurnsIncluded ()) };
      let initial_page = optional_json_kind(
        object,
        "initialTurnsPage",
        "thread/resume.params",
        "object",
      );

      if !sandbox_permissions_valid params {
        `MethodError "`permissions` cannot be combined with `sandbox`"
      } else if let `Err reason = thread_id {
        `MethodError reason
      } else if let `Err reason = history {
        `MethodError reason
      } else if let `Err reason = path {
        `MethodError reason
      } else if let `Err reason = model {
        `MethodError reason
      } else if let `Err reason = provider {
        `MethodError reason
      } else if let `Err reason = cwd {
        `MethodError reason
      } else if let `Err reason = exclude_turns {
        `MethodError reason
      } else if let `Err reason = initial_page {
        `MethodError reason
      } else if let `Ok thread_id_value = thread_id {
        if let `Ok history_value = history {
          if let `Ok path_value = path {
            if let `Ok model_value = model {
              if let `Ok provider_value = provider {
                if let `Ok cwd_value = cwd {
                  if let `Ok exclude_turns_value = exclude_turns {
                    if let `Ok initial_page_value = initial_page {
                      let decoded: ThreadMethodResumeParams = [
                        thread_id_value,
                        history_value,
                        path_value,
                        model_value,
                        provider_value,
                        cwd_value,
                        exclude_turns_value,
                        initial_page_value,
                        params,
                      ];
                      `MethodOk (`ThreadResume decoded);
                    } else { `MethodError "thread/resume.params.initialTurnsPage could not be decoded" }
                  } else { `MethodError "thread/resume.params.excludeTurns could not be decoded" }
                } else { `MethodError "thread/resume.params.cwd could not be decoded" }
              } else { `MethodError "thread/resume.params.modelProvider could not be decoded" }
            } else { `MethodError "thread/resume.params.model could not be decoded" }
          } else { `MethodError "thread/resume.params.path could not be decoded" }
        } else { `MethodError "thread/resume.params.history could not be decoded" }
      } else {
        `MethodError "thread/resume.params.threadId could not be decoded"
      }
    } else {
      `MethodError "thread/resume.params must be an object"
    }
  };

let decode_thread_fork: ThreadMethodJson -> ThreadMethodDecodeResult = (params: ThreadMethodJson) => {
    if let `Object object = params {
      let thread_id = required_text(object, "threadId", "thread/fork.params");
      let last_turn_id = optional_text(object, "lastTurnId", "thread/fork.params");
      let before_turn_id = optional_text(object, "beforeTurnId", "thread/fork.params");
      let path = optional_path(object, "thread/fork.params");
      let model = optional_text(object, "model", "thread/fork.params");
      let provider = optional_text(object, "modelProvider", "thread/fork.params");
      let cwd = optional_text(object, "cwd", "thread/fork.params");
      let ephemeral_lookup: ThreadMethodJsonLookup = json_object_get("ephemeral", object);
      let ephemeral: ThreadMethodThreadPersistenceResult = if let `Found ephemeral_json = ephemeral_lookup {
          if let `Bool ephemeral_boolean = ephemeral_json {
            if ephemeral_boolean { `Ok (`EphemeralThread ()) } else { `Ok (`PersistentThread ()) }
          } else { `Err "thread/fork.params.ephemeral must be a boolean" }
        } else { `Ok (`PersistentThread ()) };
      let exclude_turns_lookup: ThreadMethodJsonLookup = json_object_get("excludeTurns", object);
      let exclude_turns: ThreadMethodExcludeTurnsResult = if let `Found fork_exclude_json = exclude_turns_lookup {
          if let `Bool fork_exclude_boolean = fork_exclude_json {
            if fork_exclude_boolean { `Ok (`TurnsExcluded ()) } else { `Ok (`TurnsIncluded ()) }
          } else { `Err "thread/fork.params.excludeTurns must be a boolean" }
        } else { `Ok (`TurnsIncluded ()) };
      let defer_goal_lookup: ThreadMethodJsonLookup = json_object_get(
        "deferGoalContinuation",
        object,
      );
      let defer_goal: ThreadMethodGoalContinuationResult = if let `Found defer_goal_json = defer_goal_lookup {
          if let `Bool defer_goal_boolean = defer_goal_json {
            if defer_goal_boolean { `Ok (`GoalContinuationDeferred ()) } else { `Ok (
              `GoalContinuationImmediate ()
            ) }
          } else { `Err "thread/fork.params.deferGoalContinuation must be a boolean" }
        } else { `Ok (`GoalContinuationImmediate ()) };

      if !sandbox_permissions_valid params {
        `MethodError "`permissions` cannot be combined with `sandbox`"
      } else if let `Err reason = thread_id {
        `MethodError reason
      } else if let `Err reason = last_turn_id {
        `MethodError reason
      } else if let `Err reason = before_turn_id {
        `MethodError reason
      } else if let `Err reason = path {
        `MethodError reason
      } else if let `Err reason = model {
        `MethodError reason
      } else if let `Err reason = provider {
        `MethodError reason
      } else if let `Err reason = cwd {
        `MethodError reason
      } else if let `Err reason = ephemeral {
        `MethodError reason
      } else if let `Err reason = exclude_turns {
        `MethodError reason
      } else if let `Err reason = defer_goal {
        `MethodError reason
      } else if let `Ok last_value = last_turn_id {
        if let `Ok before_value = before_turn_id {
          let both_boundaries = false;
          if let `Some _ = last_value { if let `Some _ = before_value { both_boundaries = true } }

          if both_boundaries {
            `MethodError "`beforeTurnId` cannot be combined with `lastTurnId`"
          } else if let `Ok ephemeral_value = ephemeral {
            if let `Ok defer_goal_value = defer_goal {
              let ephemeral_enabled = if let `EphemeralThread () = ephemeral_value { true } else {
                false };
              let defer_goal_enabled = if let `GoalContinuationDeferred () = defer_goal_value { true
              } else { false };
              if ephemeral_enabled && defer_goal_enabled {
                `MethodError "`deferGoalContinuation` cannot be combined with `ephemeral`"
              } else if let `Ok thread_id_value = thread_id {
                if let `Ok path_value = path {
                  if let `Ok model_value = model {
                    if let `Ok provider_value = provider {
                      if let `Ok cwd_value = cwd {
                        if let `Ok exclude_turns_value = exclude_turns {
                          let decoded: ThreadMethodForkParams = [
                            thread_id_value,
                            last_value,
                            before_value,
                            path_value,
                            model_value,
                            provider_value,
                            cwd_value,
                            ephemeral_value,
                            exclude_turns_value,
                            defer_goal_value,
                            params,
                          ];
                          `MethodOk (`ThreadFork decoded);
                        } else { `MethodError "thread/fork.params.excludeTurns could not be decoded" }
                      } else { `MethodError "thread/fork.params.cwd could not be decoded" }
                    } else { `MethodError "thread/fork.params.modelProvider could not be decoded" }
                  } else { `MethodError "thread/fork.params.model could not be decoded" }
                } else { `MethodError "thread/fork.params.path could not be decoded" }
              } else { `MethodError "thread/fork.params.threadId could not be decoded" }
            } else { `MethodError "thread/fork.params.deferGoalContinuation could not be decoded" }
          } else { `MethodError "thread/fork.params.ephemeral could not be decoded" }
        } else { `MethodError "thread/fork.params.beforeTurnId could not be decoded" }
      } else {
        `MethodError "thread/fork.params.lastTurnId could not be decoded"
      }
    } else {
      `MethodError "thread/fork.params must be an object"
    }
  };

const decode_thread_archive: ThreadMethodJson -> ThreadMethodDecodeResult = (
  params: ThreadMethodJson ) => {
  if let `Object object = params {
    let thread_id = required_text(object, "threadId", "thread/archive.params");
    if let `Ok value = thread_id { `MethodOk (`ThreadArchive value) } else if let `Err reason = thread_id { `MethodError reason } else { `MethodError "thread/archive.params.threadId could not be decoded" }
  } else {
    `MethodError "thread/archive.params must be an object"
  }
};

