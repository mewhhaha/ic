module (!init: Init) where

const {} = import "./wait_for_environment_types.duck" ();
const { .finish_wait_for_environment, .plan_wait_for_environment } =
  import "./wait_for_environment_policy.duck" ();

type FixtureEnvironment = WaitForEnvironment
type FixtureEnvironmentNode = WaitForEnvironmentNode
type FixtureEnvironments = WaitForEnvironments
type FixtureHostResponse = WaitForEnvironmentHostResponse

let environments: FixtureEnvironments = `Cons (
  [[.environment_id = "gpu", .status = `Starting ()] as FixtureEnvironment, `Nil ()] as FixtureEnvironmentNode
);
let score = 0;

if let `Wait environment_id = plan_wait_for_environment(environments, "gpu") {
  response <- WaitForEnvironmentHost.wait(&environment_id)
  let typed_response: FixtureHostResponse = response;
  if let `Completed output = finish_wait_for_environment(environment_id, typed_response) {
    if output == "{\"environment_id\":\"gpu\",\"status\":\"ready\"}" { score = 1 }
  }
}

return { .score = score };
