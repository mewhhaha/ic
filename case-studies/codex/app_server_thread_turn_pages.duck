module () where

const { .parse_thread_turns_cursor, .serialize_thread_turns_cursor } =
  import "./app_server_thread_turn_cursor.duck" ();
const { .paginate_thread_turns } = import "./app_server_thread_turn_pagination.duck" ();
const {} = import "./app_server_turn_types.duck" ();
const {} = import "./app_server_types.duck" ();

type TurnPagesTurns = AppServerTurns
type TurnPagesParams = AppServerThreadTurnsListParams
type TurnPagesCursorOption = AppServerThreadTurnsCursorOption
type TurnPagesTextOption = AppServerTextOption
type TurnPagesPage = AppServerThreadTurnsPage
type TurnPagesPageResult = AppServerThreadTurnsPageResult

const serialize_optional_cursor: TurnPagesCursorOption -> TurnPagesTextOption = (
  cursor: TurnPagesCursorOption ) => {
  if let `Some value = cursor {
    `Some (serialize_thread_turns_cursor value)
  } else {
    `None ()
  }
};

let list_legacy_thread_turns: [TurnPagesTurns, TurnPagesParams] -> TurnPagesPageResult = (
  history: TurnPagesTurns,
  params: TurnPagesParams,
) => {
  let [_, encoded_cursor, page_size, sort_direction, items_view] = params;
  let cursor: TurnPagesCursorOption = `None ();
  let cursor_error: TurnPagesTextOption = `None ();

  if let `Some encoded = encoded_cursor {
    let parsed = parse_thread_turns_cursor encoded;
    if let `Ok value = parsed {
      cursor = `Some value
    } else if let `Err reason = parsed {
      cursor_error = `Some reason
    }
  }

  if let `Some reason = cursor_error {
    `Err reason
  } else {
    let paginated = paginate_thread_turns [history, cursor, page_size, sort_direction, items_view];
    if let `Ok page = paginated {
      let [turns, next_cursor, backwards_cursor] = page;
      let response: TurnPagesPage = [
        turns,
        serialize_optional_cursor next_cursor,
        serialize_optional_cursor backwards_cursor,
      ];
      `Ok response;
    } else if let `Err reason = paginated {
      `Err reason
    } else {
      `Err "thread/turns/list could not materialize a legacy page"
    }
  }
};

return {
  .list_legacy_thread_turns,
};
