module () where

const { .parse_request_user_input_args } = import "./request_user_input_json.duck" ();

let score = 0;
if let `ParseFailed message = parse_request_user_input_args "[]" {
  if message == "failed to parse function arguments: request_user_input arguments must be an object" { score = score + 1 }
}
if let `ParseFailed message = parse_request_user_input_args "{}" {
  if message == "failed to parse function arguments: questions is required" { score = score + 10 }
}
if let `ParseFailed message = parse_request_user_input_args "{\"questions\":true}" {
  if message == "failed to parse function arguments: questions must be an array" { score = score + 100 }
}
if let `ParseFailed message = parse_request_user_input_args "{\"questions\":[],\"autoResolutionMs\":18446744073709551616}" {
    if message == "failed to parse function arguments: autoResolutionMs must be an unsigned 64-bit integer" { score = score + 1000 }
  }

return { .score = score };
