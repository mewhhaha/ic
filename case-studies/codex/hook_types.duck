module () where

type HookTextOption = Option Text
type HookI32Option = Option I32
type HookTexts = List Text

type HookEvent =
  | `PreToolUse Unit
  | `PermissionRequest Unit
  | `PostToolUse Unit
  | `PreCompact Unit
  | `PostCompact Unit
  | `SessionStart Unit
  | `SessionEnd Unit
  | `UserPromptSubmit Unit
  | `SubagentStart Unit
  | `SubagentStop Unit
  | `Stop Unit

type HookScope =
  | `Thread Unit
  | `Turn Unit

type HookSource =
  | `System Unit
  | `User Unit
  | `Project Unit
  | `Mdm Unit
  | `SessionFlags Unit
  | `Plugin Unit
  | `CloudRequirements Unit
  | `CloudManagedConfig Unit
  | `LegacyManagedConfigFile Unit
  | `LegacyManagedConfigMdm Unit
  | `Unknown Unit

type HookMatcher =
  | `MatchAll Unit
  | `Exact HookTexts
  | `Regex Text

type HookMatcherParse =
  | `Ok HookMatcher
  | `Err Text

type HookCommandConfig = [Text, HookI32Option, Bool, HookTextOption]
type HookHandlerConfig =
  | `Command HookCommandConfig
  | `Prompt Unit
  | `Agent Unit

type HookConfiguredHandler = [
  HookEvent,
  HookMatcher,
  Text,
  I32,
  HookTextOption,
  Text,
  HookSource,
  I32 ]
type HookConfiguredHandlers = List HookConfiguredHandler
type HookConfiguredHandlerWithWarnings = [HookConfiguredHandler, HookTexts]

type HookHandlerNormalization =
  | `Configured HookConfiguredHandlerWithWarnings
  | `Skipped Text

type HookTrustStatus =
  | `Managed Unit
  | `Trusted Unit
  | `Modified Unit
  | `Untrusted Unit

type HookEnabledState =
  | `DefaultEnabled Unit
  | `Enabled Unit
  | `Disabled Unit

type HookTrustedHash =
  | `NoTrustedHash Unit
  | `TrustedHash Text

type HookState = [HookEnabledState, HookTrustedHash]
type HookStateOption =
  | `MissingHookState Unit
  | `PresentHookState HookState

type HookPermissionDecision =
  | `Allow Unit
  | `Deny Text

type HookPermissionDecisions = List HookPermissionDecision
type HookPermissionDecisionOption = Option HookPermissionDecision

type HookRunStatus =
  | `Completed Unit
  | `Failed Unit
  | `Blocked Unit
  | `Stopped Unit

type HookOutputEntryKind =
  | `Warning Unit
  | `Stop Unit
  | `Feedback Unit
  | `Context Unit
  | `Error Unit

type HookOutputEntry = [HookOutputEntryKind, Text]
type HookOutputEntries = List HookOutputEntry

type HookUpdatedInput =
  | `NoUpdatedInput Unit
  | `UpdatedInput Text

type HookLegacyResult =
  | `Success Unit
  | `FailedContinue Text
  | `FailedAbort Text

type HookLegacyResults = List HookLegacyResult

type HookLegacyOutcome = [Bool, Text, I32]

type HookCommandRequest = [Text, Text, Text, I32]
type HookCommandResult = [HookTextOption, HookI32Option, Text, Text]
type HookCommandCompletion =
  | `Exited I32
  | `ProcessFailed Text
  | `MissingExit Unit
type HookCommandOutcome = [HookCommandCompletion, HookTextOption]

return {};
