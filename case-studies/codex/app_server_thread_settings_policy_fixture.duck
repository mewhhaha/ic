module () where

const { .json_object, .json_object_empty, .json_string } = import "duck:prelude/json/values" ();
const { .list } = import "duck:prelude/functional" ();
const { .plan_thread_settings_update } = import "./app_server_thread_settings.duck" ();
const {} = import "./app_server_thread_settings_types.duck" ();

type FixtureParams = AppServerThreadSettingsUpdateParams
type FixturePlanResult = AppServerThreadSettingsUpdatePlanResult
type FixturePlanInput = AppServerThreadSettingsUpdatePlanInput
type FixtureResolution = AppServerThreadPermissionResolution
type FixturePermission = AppServerThreadPermissionSettings
type FixtureTextOption = AppServerTextOption
type FixtureJsonOption = AppServerJsonOption
type FixtureJson = AppServerJson
type FixtureTexts = AppServerTexts

const texts = comptime list Text;
const json_string_is = (value: FixtureJson, expected: Text) => if let `String text = value { text == expected } else { false };
let no_text: FixtureTextOption = `None ();
let no_json: FixtureJsonOption = `None ();
let roots: FixtureTexts = texts.prepend("/old", texts.prepend("/extra", texts.singleton("/new")));
let params: FixtureParams = [
  "thread-1",
  `Some "/new",
  `Some (json_string "never"),
  no_json,
  no_json,
  no_text,
  `Some "new-model",
  `Clear (),
  `Some "high",
  no_text,
  no_json,
  no_text,
  true,
  json_object(json_object_empty()),
];
let not_requested: FixtureResolution = `PermissionSelectionNotRequested ();
let input: FixturePlanInput = ["/old", roots, not_requested, params];
let planned: FixturePlanResult = plan_thread_settings_update input;
let score = 0;

if let `ThreadSettingsUpdatePlanned plan = planned {
  let overrides = plan.overrides;
  let roots_valid = false;
  if let `Cons first_node = plan.workspace_roots {
    let [first, after_first] = first_node;
    if let `Cons second_node = after_first {
      let [second, done] = second_node;
      if let `Nil () = done { roots_valid = first == "/new" && second == "/extra" }
    }
  }
  let cwd_valid = if let `Some cwd = overrides.cwd { cwd == "/new" } else { false };
  let model_valid = if let `Some model = overrides.model { model == "new-model" } else { false };
  let approval_valid = if let `Some approval = overrides.approval_policy { json_string_is(
    approval,
    "never",
  ) } else { false };
  let tier_valid = if let `Clear () = overrides.service_tier { true } else { false };
  let effort_valid = if let `Some effort = overrides.effort { effort == "high" } else { false };
  if plan.thread_id == "thread-1" && cwd_valid && model_valid && approval_valid && roots_valid && tier_valid && effort_valid { score = score + 1 }
}

let no_change: FixtureParams = [
  "thread-1",
  no_text,
  no_json,
  no_json,
  no_json,
  no_text,
  no_text,
  `Keep (),
  no_text,
  no_text,
  no_json,
  no_text,
  false,
  json_object(json_object_empty()),
];
let no_change_input: FixturePlanInput = ["/old", roots, not_requested, no_change];
let unchanged: FixturePlanResult = plan_thread_settings_update no_change_input;
if let `NoThreadSettingsChanges () = unchanged { score = score + 10 }

let permission: FixturePermission = [
  json_string "unless-trusted",
  json_string "user",
  json_string "workspace-write",
  `Some (json_string "workspace"),
];
let resolved: FixtureResolution = `PermissionSelectionResolved permission;
let permission_params: FixtureParams = [
  "thread-1",
  no_text,
  `Some (json_string "on-request"),
  no_json,
  no_json,
  `Some ":workspace",
  no_text,
  `Keep (),
  no_text,
  no_text,
  no_json,
  no_text,
  true,
  json_object(json_object_empty()),
];
let permission_input: FixturePlanInput = ["/old", roots, resolved, permission_params];
let selected: FixturePlanResult = plan_thread_settings_update permission_input;
if let `ThreadSettingsUpdatePlanned plan = selected {
  let profile_valid = if let `Some profile = plan.overrides.active_permission_profile {
    json_string_is(
      profile,
      "workspace",
    ) } else { false };
  let approval_valid = if let `Some approval = plan.overrides.approval_policy { json_string_is(
    approval,
    "on-request",
  ) } else { false };
  let reviewer_valid = if let `Some reviewer = plan.overrides.approvals_reviewer { json_string_is(
    reviewer,
    "user",
  ) } else { false };
  let sandbox_valid = if let `Some sandbox = plan.overrides.sandbox_policy { json_string_is(
    sandbox,
    "workspace-write",
  ) } else { false };
  if approval_valid && reviewer_valid && sandbox_valid && profile_valid && plan.overrides.permission_selected { score = score + 100 }
}

return { .score = score };
