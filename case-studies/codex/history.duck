  let current = values;
  let matched = false;
  let done = false;

  loop {
    if let `Cons node = current {
      let [item, tail] = node;
      let candidate = custom_output_call_id item;
      let candidate_matches = if let `Some existing_call_id = candidate {
        existing_call_id == call_id
      } else {
        false
      };

      if candidate_matches {
        matched = true
        done = true
      } else {
        current = tail
      }
    } else {
      done = true
    }

    if done {
      break;
    }
  }

  matched
};

const has_custom_call = (values: NormalizedHistoryItems, call_id: Text) => {
  let current = values;
  let matched = false;
  let done = false;

  loop {
    if let `Cons node = current {
      let [item, tail] = node;
      let candidate = custom_call_call_id item;
      let candidate_matches = if let `Some existing_call_id = candidate {
        existing_call_id == call_id
      } else {
        false
      };

      if candidate_matches {
        matched = true
        done = true
      } else {
        current = tail
      }
    } else {
      done = true
    }

    if done {
      break;
    }
  }

  matched
};

const has_tool_search_output = (values: NormalizedHistoryItems, call_id: Text) => {
  let current = values;
  let matched = false;
  let done = false;

  loop {
    if let `Cons node = current {
      let [item, tail] = node;
      let candidate = tool_search_output_call_id item;
      let candidate_matches = if let `Some existing_call_id = candidate {
        existing_call_id == call_id
      } else {
        false
      };

      if candidate_matches {
        matched = true
        done = true
      } else {
        current = tail
      }
    } else {
      done = true
    }

    if done {
      break;
    }
  }

  matched
};

const has_tool_search_call = (values: NormalizedHistoryItems, call_id: Text) => {
  let current = values;
  let matched = false;
  let done = false;

  loop {
    if let `Cons node = current {
      let [item, tail] = node;
      let candidate = tool_search_call_call_id item;
      let candidate_matches = if let `Some existing_call_id = candidate {
        existing_call_id == call_id
      } else {
        false
      };

      if candidate_matches {
        matched = true
