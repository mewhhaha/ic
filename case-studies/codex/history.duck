module () where

const { .list, .text_append, .text_length } = import "duck:prelude/functional" ();
const history_types_module = import "./history_types.duck";

type NormalizedHistoryContent = HistoryContent
type NormalizedHistoryContents = HistoryContents
type NormalizedHistoryMessage = HistoryMessage
type NormalizedHistoryOutput = HistoryOutput
type NormalizedHistoryToolSearchOutput = HistoryToolSearchOutput
type NormalizedHistoryItem = HistoryItem
type NormalizedHistoryItems = HistoryItems
type NormalizedHistoryItemOption = HistoryItemOption
type NormalizedHistoryTextOption = HistoryTextOption
type NormalizedInputModalities = InputModalities

const history_item_list = comptime list NormalizedHistoryItem;
const history_content_list = comptime list NormalizedHistoryContent;

const function_output_call_id = (item: NormalizedHistoryItem) => if let `FunctionOutput output = item {
    let [_, call_id, _] = output;
    `Some call_id;
  } else {
    `None ()
  };

const function_call_call_id = (item: NormalizedHistoryItem) => if let `FunctionCall call = item {
  let [_, call_id, _, _] = call;
  `Some call_id;
} else if let `LocalShellCall call = item {
  let [_, call_id] = call;
  `Some call_id;
} else {
  `None ()
};

const custom_output_call_id = (item: NormalizedHistoryItem) => if let `CustomOutput output = item {
  let [_, call_id, _] = output;
  `Some call_id;
} else {
  `None ()
};

const custom_call_call_id = (item: NormalizedHistoryItem) => if let `CustomCall call = item {
  let [_, call_id, _, _] = call;
  `Some call_id;
} else {
  `None ()
};

const tool_search_output_call_id = (item: NormalizedHistoryItem) => if let `ToolSearchOutput output = item {
    let [call_id, _] = output;
    `Some call_id;
  } else {
    `None ()
  };

const tool_search_call_call_id = (item: NormalizedHistoryItem) => if let `ToolSearchCall call = item {
    let [_, call_id] = call;
    `Some call_id;
  } else {
    `None ()
  };

const has_function_output = (values: NormalizedHistoryItems, call_id: Text) => {
  let current = values;
  let matched = false;
  let done = false;

  loop {
    if let `Cons node = current {
      let [item, tail] = node;
      let candidate = function_output_call_id item;
      let candidate_matches = if let `Some existing_call_id = candidate {
        existing_call_id == call_id
      } else {
        false
      };

      if candidate_matches {
        matched = true
        done = true
      } else {
        current = tail
      }
    } else {
      done = true
    }

    if done {
      break;
    }
  }

  matched
};

const has_function_call = (values: NormalizedHistoryItems, call_id: Text) => {
  let current = values;
  let matched = false;
  let done = false;

  loop {
    if let `Cons node = current {
      let [item, tail] = node;
      let candidate = function_call_call_id item;
      let candidate_matches = if let `Some existing_call_id = candidate {
        existing_call_id == call_id
      } else {
        false
      };

      if candidate_matches {
        matched = true
        done = true
      } else {
        current = tail
      }
    } else {
      done = true
    }

    if done {
      break;
    }
  }

  matched
};

