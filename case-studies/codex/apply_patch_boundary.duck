module () where

const { .list } = import "duck:prelude/list" ();
const { .text_ends_with, .text_split, .text_trim_ascii_whitespace } = import "duck:prelude/text" ();
const {} = import "./apply_patch_types.duck" ();

type PatchBoundaryTexts = ApplyPatchTexts
type PatchBoundaryResult = ApplyPatchLinesResult

const texts = comptime list Text;

let normalize_apply_patch_lines: Text -> PatchBoundaryResult = (patch: Text) => {
  let lines: PatchBoundaryTexts = text_split [text_trim_ascii_whitespace patch, "\n"];
  let line_count = texts.length(lines);

  if line_count >= 4 {
    let first = texts.nth_or("", 0, lines);
    let last = texts.nth_or("", line_count - 1, lines);
    let heredoc = first == "<<EOF" || first == "<<'EOF'" || first == "<<\"EOF\"";
    if heredoc && text_ends_with [last, "EOF"] {
      lines = texts.take(line_count - 2, texts.drop(1, lines))
      line_count = texts.length(lines)
    }
  }

  if line_count == 0 || text_trim_ascii_whitespace(texts.nth_or("", 0,
    lines)) != "*** Begin Patch" {
      `Err "invalid patch: The first line of the patch must be '*** Begin Patch'"
    } else if text_trim_ascii_whitespace(texts.nth_or("", line_count - 1, lines)) != "*** End Patch" {
    `Err "invalid patch: The last line of the patch must be '*** End Patch'"
  } else {
    `Ok lines
  }
};

return { .normalize_apply_patch_lines };
