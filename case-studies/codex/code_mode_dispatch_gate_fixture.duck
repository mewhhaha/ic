module () where

const {} = import "./code_mode_dispatch_types.duck" ();
const { .plan_code_mode_dispatch_gate } = import "./code_mode_dispatch.duck" ();

type FixtureFacts = CodeModeDispatchGateFacts
type FixtureInvocation = CodeModeNestedToolInvocation
type FixtureNotification = CodeModeNotification
type FixtureRequest = CodeModeDispatchRequest

let invocation: FixtureInvocation = [
  .cell_id = "cell-tool",
  .runtime_tool_call_id = "runtime-tool",
  .tool_name = ["", "lookup"],
  .tool_kind = `NestedFunction (),
  .input = `None ()];
let nested_request: FixtureRequest = `DispatchNestedInvocation invocation;
let notification: FixtureNotification = [
  .call_id = "call-notify",
  .cell_id = "cell-notify",
  .text = "working"];
let notification_request: FixtureRequest = `DispatchNotification notification;

let score = 0;

let nested_waiting: FixtureFacts = [
  .request = nested_request,
  .cancellation = `DispatchActive (),
  .gate = `DispatchGateWaiting ()];
if let `WaitForCodeModeDispatchGate cell_id = plan_code_mode_dispatch_gate nested_waiting {
  if cell_id == "cell-tool" { score = score + 1 }
}

let notification_waiting: FixtureFacts = [
  .request = notification_request,
  .cancellation = `DispatchActive (),
  .gate = `DispatchGateWaiting ()];
if let `WaitForCodeModeDispatchGate cell_id = plan_code_mode_dispatch_gate notification_waiting {
  if cell_id == "cell-notify" { score = score + 10 }
}

let nested_ready: FixtureFacts = [
  .request = nested_request,
  .cancellation = `DispatchActive (),
  .gate = `DispatchGateReady ()];
if let `SpawnNestedToolDispatch ready_invocation = plan_code_mode_dispatch_gate nested_ready {
  if ready_invocation.runtime_tool_call_id == "runtime-tool" { score = score + 100 }
}

let notification_ready: FixtureFacts = [
  .request = notification_request,
  .cancellation = `DispatchActive (),
  .gate = `DispatchGateReady ()];
if let `RunCodeModeNotification ready_notification = plan_code_mode_dispatch_gate notification_ready {
    if ready_notification.call_id == "call-notify" { score = score + 1000 }
  }

let nested_cancelled: FixtureFacts = [
  .request = nested_request,
  .cancellation = `DispatchCancelled (),
  .gate = `DispatchGateReady ()];
if let `CloseNestedToolDispatchGate cell_id = plan_code_mode_dispatch_gate nested_cancelled {
  if cell_id == "cell-tool" { score = score + 10000 }
}

let notification_closed: FixtureFacts = [
  .request = notification_request,
  .cancellation = `DispatchActive (),
  .gate = `DispatchGateClosed ()];
if let `CloseNotificationDispatchGate closed = plan_code_mode_dispatch_gate notification_closed {
  if closed.cell_id == "cell-notify" && closed.error == "code mode notification cancelled" {
    score = score + 100000
  }
}

return { .score = score };
