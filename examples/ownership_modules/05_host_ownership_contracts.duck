module (!init: Init) where

const _ = import "duck:prelude/runtime" ()

declare effect Host {
  read: (&Text) => I32
  take: (Text) => I32
}

declare Init { host: Host }

let read_message: Text = "a" <> "b"
read_result <- Host.read(&read_message)

let sent_message: Text = "c" <> "d"
send_result <- Host.take(sent_message)

let result = read_result + send_result
return { .result = result }
