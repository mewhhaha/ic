// Declare source-level operator syntax separately from implementation.
infixl 4 (+);

// Signatures are source facts. They are parsed now and will become useful
// once the frontend grows a real type checker.
fn (+) : i32 -> i32 -> i32;
fn (+) a b = @i32_add a b;

// Repeated source variables lower into explicit IC duplication.
fn test : i32 -> i32;
fn test x = x + x;

// Export a concrete value, and also execute it as main.
export let result = test 21i32;
result;
