type NumberCalc = | `Literal Int | `Add Int
type TextCalc = `Literal Text

let eval_number = expression => {
  if let `Literal value = expression {
    value
  } else {
    if let `Add left = expression {
      left + 22
    } else {
      0
    }
  }
}

let expression: NumberCalc = `Add (20)

eval_number(expression)
