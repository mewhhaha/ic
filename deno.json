{
  "tasks": {
    "duck": "deno run --allow-read --allow-write --allow-run=wat2wasm duck.ts",
    "compiler:perf": "deno run --allow-read scripts/compiler-performance.ts",
    "compiler:gpufuck": "deno run --unstable-webgpu --allow-read --allow-write experiments/gpufuck/compile.ts",
    "compiler:gpufuck:bench": "deno run --unstable-webgpu --allow-read experiments/gpufuck/benchmark.ts",
    "compiler:gpufuck:runtime": "deno run --unstable-webgpu --allow-read --allow-write --allow-run=wat2wasm experiments/gpufuck/runtime_benchmark.ts",
    "compiler:gpufuck:test": "deno test --unstable-webgpu --allow-read experiments/gpufuck/compiler.test.ts",
    "lsp:perf": "deno run --allow-read scripts/lsp-performance.ts"
  },
  "imports": {
    "@mewhhaha/typeclasses": "jsr:@mewhhaha/typeclasses@^0.5.0"
  },
  "minimumDependencyAge": {
    "age": "P7D",
    "exclude": [
      "jsr:@mewhhaha/*"
    ]
  },
  "fmt": {
    "exclude": [
      "AGENTS.md",
      "tree-sitter-duck/src/grammar.json",
      "tree-sitter-duck/src/node-types.json"
    ]
  }
